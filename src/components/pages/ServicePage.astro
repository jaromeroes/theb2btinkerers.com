---
import Base from '../../layouts/Base.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { serviceDetail, servicesCommon } from '../../i18n/pages/services';
import { mirrorAlternates, localizePath } from '../../i18n/utils';
import { fmtShortDate } from '../../i18n/pages/insights';
import type { Lang } from '../../i18n/config';
import type { ServiceSlug } from '../../i18n/services-nav';

// Hero + case images per service.
import auditHero from '../../assets/services/marketing-audit-hero.webp';
import auditCase from '../../assets/services/marketing-audit-case-study.webp';
import aiHero from '../../assets/services/ai-strategy-hero.webp';
import aiCase from '../../assets/services/ai-strategy-case-study.webp';
import brandHero from '../../assets/services/brand-strategy-hero.webp';
import brandCase from '../../assets/services/brand-strategy-case-study.webp';
import gtmHero from '../../assets/services/go-to-market-hero.webp';
import gtmCase from '../../assets/services/go-to-market-case-study.webp';
import planHero from '../../assets/services/marketing-plan-hero.webp';
import planCase from '../../assets/services/marketing-plan-case-study.webp';
import cmoHero from '../../assets/services/fractional-cmo-hero.webp';
import cmoCase from '../../assets/services/fractional-cmo-case-study.webp';

interface Props { lang: Lang; slug: ServiceSlug }
const { lang, slug } = Astro.props;
const t = serviceDetail[lang][slug];
const c = servicesCommon[lang];
const p = (path: string) => localizePath(path, lang);

const images: Record<ServiceSlug, { hero: ImageMetadata; case: ImageMetadata }> = {
  'marketing-audit': { hero: auditHero, case: auditCase },
  'ai-strategy': { hero: aiHero, case: aiCase },
  'brand-strategy': { hero: brandHero, case: brandCase },
  'go-to-market': { hero: gtmHero, case: gtmCase },
  'marketing-plan': { hero: planHero, case: planCase },
  'fractional-cmo': { hero: cmoHero, case: cmoCase },
};

// Inner SVG paths for each service's four "what we deliver" icons.
const deliverIcons: Record<ServiceSlug, string[]> = {
  'marketing-audit': [
    '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>',
    '<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>',
    '<circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 21V9a9 9 0 0 0 9 9"/>',
    '<line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><polyline points="3 6 4 7 6 5"/><polyline points="3 12 4 13 6 11"/><polyline points="3 18 4 19 6 17"/>',
  ],
  'ai-strategy': [
    '<rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 9h.01"/><path d="M15 9h.01"/><path d="M9 15h.01"/><path d="M15 15h.01"/><path d="M9 12h6"/><path d="M12 9v6"/>',
    '<polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>',
    '<path d="M12 2l-2 7H3l5.5 4.5L6 21l6-4.5L18 21l-2.5-7.5L21 9h-7z"/><circle cx="12" cy="12" r="3"/><path d="M5 5l1.5 1.5"/><path d="M17.5 17.5L19 19"/><path d="M19 5l-1.5 1.5"/><path d="M5.5 17.5L4 19"/>',
    '<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/><path d="M18 6l2-2 2 2"/><path d="M20 4v6"/>',
  ],
  'brand-strategy': [
    '<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/>',
    '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
    '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
    '<path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>',
  ],
  'go-to-market': [
    '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
    '<path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>',
    '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
    '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
  ],
  'marketing-plan': [
    '<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>',
    '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>',
    '<path d="M21.21 15.89A10 10 0 1 1 8 2.83"/><path d="M22 12A10 10 0 0 0 12 2v10z"/>',
    '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  ],
  'fractional-cmo': [
    '<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M9 16l2 2 4-4"/>',
    '<circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>',
    '<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>',
    '<path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/>',
  ],
};

// Related-post tag filters per service, per language.
const relatedTagsByLang: Record<Lang, Record<ServiceSlug, string[]>> = {
  en: {
    'marketing-audit': ['strategy', 'b2b marketing strategy'],
    'ai-strategy': ['ai', 'ai & marketing'],
    'brand-strategy': ['strategy', 'b2b marketing strategy'],
    'go-to-market': ['strategy', 'b2b marketing strategy'],
    'marketing-plan': ['strategy', 'b2b marketing strategy'],
    'fractional-cmo': ['fractional cmo', 'strategy', 'b2b marketing strategy'],
  },
  es: {
    'marketing-audit': ['estrategia', 'estrategia de marketing b2b'],
    'ai-strategy': ['ia', 'ia y marketing'],
    'brand-strategy': ['estrategia', 'estrategia de marketing b2b'],
    'go-to-market': ['estrategia', 'estrategia de marketing b2b'],
    'marketing-plan': ['estrategia', 'estrategia de marketing b2b'],
    'fractional-cmo': ['cmo fraccional', 'estrategia', 'estrategia de marketing b2b'],
  },
};

const relatedTags = relatedTagsByLang[lang][slug];
const relatedPosts = (await getCollection('blog'))
  .filter(post => post.data.lang === lang && relatedTags.includes(post.data.tag.toLowerCase()))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const img = images[slug];
---
<Base lang={lang} title={t.seo.title} description={t.seo.description} alternates={mirrorAlternates(`/services/${slug}`)}>

<!-- HERO -->
<section class="sv-hero">
  <div class="sv-hero-bg">
    <Image src={img.hero} alt={t.heroImgAlt} format="webp" quality={85} loading="eager" fetchpriority="high" style="width:100%;height:100%;object-fit:cover;display:block;" />
  </div>
  <div class="sv-hero-overlay"></div>
  <div class="sv-hero-content">
    <div class="sv-eyebrow">{t.heroNum}</div>
    <h1 class="sv-h1" set:html={t.titleLines.join('<br/>')}></h1>
    <p class="sv-subtitle">{t.subtitle}</p>
  </div>
</section>

<!-- THE PROBLEM -->
<section class="sv-problem">
  <div class="sv-problem-inner">
    <div class="sv-problem-left">
      <div class="section-eyebrow">{c.challenge}</div>
      <h2 class="sv-h2" set:html={t.problem.titleLines.join('<br/>')}></h2>
    </div>
    <div class="sv-problem-right">
      {t.problem.paragraphs.map(par => <p>{par}</p>)}
    </div>
  </div>
</section>

<!-- WHAT WE DELIVER -->
<section class="sv-deliver">
  <div class="sv-deliver-inner">
    <div class="sv-deliver-header">
      <div class="section-eyebrow">{c.whatWeDeliver}</div>
      <h2 class="sv-h2">{t.deliver.h2}</h2>
      <p class="sv-deliver-intro">{t.deliver.intro}</p>
    </div>
    <div class="sv-deliver-grid">
      {t.deliver.cards.map((card, i) => (
        <div class="sv-deliver-card">
          <div class="sv-deliver-head">
            <svg class="sv-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={deliverIcons[slug][i]}></svg>
            <div class="sv-deliver-label">{card.label}</div>
          </div>
          <div class="sv-deliver-desc">{card.desc}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- HOW WE WORK -->
<section class="sv-process">
  <div class="sv-process-inner">
    <div class="section-eyebrow">{c.howWeWork}</div>
    <h2 class="sv-h2">{t.process.h2}</h2>
    <div class="sv-process-grid">
      {t.process.steps.map(step => (
        <div class="sv-process-step">
          <span class="sv-process-num">{step.num}</span>
          <div class="sv-process-title">{step.title}</div>
          <div class="sv-process-body">{step.body}</div>
          <span class="sv-process-tag">{step.tag}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- STATS -->
<section class="sv-stats">
  <div class="sv-stats-inner">
    <div class="section-eyebrow sv-stats-eyebrow">{c.theNumbers}</div>
    <h2 class="sv-h2 sv-stats-title">{t.stats.h2}</h2>
    <div class="sv-stats-grid">
      {t.stats.items.map((stat, i) => (
        <div class={`sv-stat-card sv-stat-${i + 1}`}>
          <span class="sv-stat-num">{stat.num}</span>
          <span class="sv-stat-label">{stat.label}</span>
          <span class="sv-stat-source">{stat.source}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CASE STUDY -->
<section class="sv-case">
  <div class="sv-case-inner">
    <div class="section-eyebrow">{c.caseInPoint}</div>
    <div class="sv-case-grid">
      <div class="sv-case-text">
        <h2 class="sv-h2">{t.caseStudy.h2}</h2>
        {t.caseStudy.paragraphs.map(par => <p>{par}</p>)}
      </div>
      <div class="sv-case-img">
        <Image src={img.case} alt={t.caseStudy.imgAlt} format="webp" quality={85} loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
      </div>
    </div>
  </div>
</section>

<!-- RELATED INSIGHTS -->
{relatedPosts.length > 0 && (
<section class="sv-insights">
  <div class="sv-insights-inner">
    <div class="sv-insights-header">
      <div>
        <div class="section-eyebrow">{c.relatedInsights}</div>
        <h2 class="sv-h2">{t.relatedH2}</h2>
      </div>
      <a class="sv-insights-all" href={p('/insights')}>{c.allArticles}</a>
    </div>
    <div class="sv-insights-grid">
      {relatedPosts.map(post => (
        <a class="sv-insight-card" href={p(`/insights/${post.slug}`)}>
          <span class="sv-insight-tag">{post.data.tag}</span>
          <div class="sv-insight-title">{post.data.title}</div>
          <div class="sv-insight-meta">
            <span class="sv-insight-date">{fmtShortDate(post.data.date, lang)}</span>
            <span class="sv-insight-arrow">{c.readMore}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
)}

<!-- CTA -->
<section class="sv-cta">
  <div class="sv-cta-inner">
    <h2 class="sv-cta-h2">{t.cta.h2}</h2>
    <p class="sv-cta-sub">{t.cta.sub}</p>
    <a class="btn-primary" href="#contact">{lang === 'es' ? 'Hablemos →' : "Let's talk →"}</a>
  </div>
</section>

</Base>

<style>
/* HERO */
.sv-hero{position:relative;min-height:50vh;padding:calc(68px + clamp(48px,7vw,80px)) var(--pad) clamp(48px,6vw,72px);display:flex;align-items:flex-end;overflow:hidden}
.sv-hero-bg{position:absolute;inset:0;z-index:0}
.sv-hero-overlay{position:absolute;inset:0;z-index:1;background:linear-gradient(120deg,rgba(7,35,26,.94) 0%,rgba(13,51,36,.82) 45%,rgba(31,115,81,.42) 100%)}
.sv-hero-content{position:relative;z-index:2;max-width:620px}
.sv-eyebrow{font-size:13px;font-weight:600;letter-spacing:.01em;color:var(--chartreuse);display:inline-block;margin-bottom:18px}
.sv-eyebrow::before{display:none}
.sv-h1{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(30px,5vw,64px);font-weight:800;letter-spacing:-0.04em;line-height:.97;color:var(--cream);margin-bottom:24px}
.sv-subtitle{font-size:clamp(14px,1.8vw,17px);line-height:1.85;color:rgba(245,240,232,0.62);max-width:600px}
@media(max-width:820px){
  .sv-hero{min-height:auto;padding-top:calc(68px + 44px)}
  .sv-hero-overlay{background:linear-gradient(180deg,rgba(7,35,26,.92) 0%,rgba(13,51,36,.9) 100%)}
}

/* PROBLEM */
.sv-problem{padding:clamp(72px,9vw,112px) var(--pad);background:var(--cream)}
.sv-problem-inner{display:grid;grid-template-columns:1fr 1.6fr;gap:clamp(36px,6vw,88px);align-items:start}
@media(max-width:760px){.sv-problem-inner{grid-template-columns:1fr}}
.sv-h2{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(22px,3vw,38px);font-weight:800;letter-spacing:-0.04em;line-height:1.05;color:var(--forest);margin-bottom:16px}
.sv-problem-right p{font-size:clamp(14px,1.6vw,16px);line-height:1.9;color:rgba(26,26,26,.65);margin-bottom:22px}
.sv-problem-right p:last-child{margin-bottom:0}

/* DELIVER */
.sv-deliver{padding:clamp(72px,9vw,112px) var(--pad);background:var(--linen)}
.sv-deliver-inner{max-width:1100px}
.sv-deliver-header{max-width:640px;margin-bottom:clamp(36px,5vw,56px)}
.sv-deliver-intro{font-size:clamp(13px,1.5vw,15px);line-height:1.85;color:var(--gray)}
.sv-deliver-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:2px}
@media(max-width:520px){.sv-deliver-grid{grid-template-columns:1fr}}
.sv-deliver-card{background:var(--cream);padding:clamp(24px,3vw,36px) clamp(20px,2.5vw,28px);transition:background .2s}
.sv-deliver-card:hover{background:var(--forest)}
.sv-deliver-head{display:flex;align-items:center;gap:12px;margin-bottom:12px}
.sv-icon{width:22px;height:22px;color:var(--forest);flex-shrink:0;transition:color .2s}
.sv-deliver-card:hover .sv-icon{color:var(--lime)}
.sv-deliver-label{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(14px,1.8vw,17px);font-weight:700;color:var(--forest);line-height:1.25;transition:color .2s}
.sv-deliver-card:hover .sv-deliver-label{color:var(--cream)}
.sv-deliver-desc{font-size:12.5px;line-height:1.7;color:rgba(26,26,26,.6);transition:color .2s}
.sv-deliver-card:hover .sv-deliver-desc{color:rgba(245,240,232,.58)}

/* PROCESS */
.sv-process{padding:clamp(72px,9vw,112px) var(--pad);background:var(--cream)}
.sv-process-inner{max-width:1100px}
.sv-process-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2px}
@media(max-width:900px){.sv-process-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:480px){.sv-process-grid{grid-template-columns:1fr}}
.sv-process-step{background:var(--linen);padding:clamp(20px,3vw,32px) clamp(16px,2.5vw,24px);transition:background .2s}
.sv-process-step:hover{background:var(--forest)}
.sv-process-num{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:40px;font-weight:800;color:var(--forest);opacity:.2;display:block;line-height:1;margin-bottom:4px;transition:color .2s,opacity .2s}
.sv-process-step:hover .sv-process-num{color:var(--cream);opacity:.09}
.sv-process-title{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(14px,1.8vw,17px);font-weight:700;color:var(--forest);margin-bottom:10px;transition:color .2s}
.sv-process-step:hover .sv-process-title{color:var(--cream)}
.sv-process-body{font-size:12px;line-height:1.7;color:rgba(26,26,26,.55);transition:color .2s}
.sv-process-step:hover .sv-process-body{color:rgba(245,240,232,.55)}
.sv-process-tag{display:inline-block;margin-top:14px;background:var(--chartreuse);color:var(--ink);font-size:10px;font-weight:700;letter-spacing:.04em;padding:5px 11px;border-radius:4px}

/* STATS */
.sv-stats{padding:clamp(56px,8vw,104px) var(--pad);background:var(--cream)}
.sv-stats-inner{max-width:1100px;margin:0 auto}
.sv-stats-eyebrow{margin-bottom:16px}
.sv-stats-title{color:var(--ink);margin-bottom:clamp(24px,3vw,40px)}
.sv-stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(20px,3vw,44px)}
@media(max-width:700px){.sv-stats-grid{grid-template-columns:1fr;gap:0}}
.sv-stat-card{padding:26px 0;border-top:2px solid var(--chartreuse)}
.sv-stat-num{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(38px,5vw,60px);font-weight:800;line-height:1;display:block;margin-bottom:12px;color:var(--ink);letter-spacing:-.03em}
.sv-stat-label{font-size:14px;line-height:1.55;display:block;color:var(--ink-2);max-width:30ch}
.sv-stat-source{display:block;margin-top:14px;font-size:11px;color:var(--gray)}

/* CASE STUDY */
.sv-case{padding:clamp(72px,9vw,112px) var(--pad);background:var(--cream)}
.sv-case-inner{max-width:1100px}
.sv-case-grid{display:grid;grid-template-columns:1fr 1fr;gap:clamp(28px,4vw,48px);align-items:start}
@media(max-width:700px){.sv-case-grid{grid-template-columns:1fr}}
.sv-case-text p{font-size:clamp(13px,1.5vw,15px);line-height:1.9;color:rgba(26,26,26,.6);margin-bottom:18px}
.sv-case-text p:last-child{margin-bottom:0}
.sv-case-img{overflow:hidden;aspect-ratio:16/9}

/* RELATED INSIGHTS */
.sv-insights{padding:clamp(72px,9vw,112px) var(--pad);background:var(--cream);border-top:1px solid rgba(28,74,58,0.06)}
.sv-insights-inner{max-width:1100px}
.sv-insights-header{display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:clamp(32px,5vw,48px)}
.sv-insights-header .sv-h2{margin-bottom:0}
.sv-insights-all{font-size:12px;font-weight:600;color:var(--forest);border-bottom:1px solid rgba(28,74,58,0.3);padding-bottom:2px;text-decoration:none;transition:border-color .15s}
.sv-insights-all:hover{border-color:var(--forest)}
.sv-insights-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
@media(max-width:700px){.sv-insights-grid{grid-template-columns:1fr}}
.sv-insight-card{background:var(--linen);padding:clamp(24px,3vw,34px);text-decoration:none;display:flex;flex-direction:column;transition:background .2s}
.sv-insight-card:hover{background:#ddd8ce}
.sv-insight-tag{font-size:12px;font-weight:600;letter-spacing:.01em;color:var(--chartreuse-deep);margin-bottom:12px;display:block}
.sv-insight-title{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(14px,1.8vw,18px);font-weight:700;line-height:1.25;color:var(--forest);margin-bottom:auto;padding-bottom:20px;flex:1}
.sv-insight-meta{display:flex;align-items:center;justify-content:space-between;padding-top:14px;border-top:1px solid rgba(28,74,58,.1)}
.sv-insight-date{font-size:10px;color:rgba(28,74,58,.55)}
.sv-insight-arrow{font-size:11px;font-weight:600;color:var(--forest);opacity:.5;transition:opacity .2s}
.sv-insight-card:hover .sv-insight-arrow{opacity:1}

/* CTA */
.sv-cta{padding:clamp(56px,8vw,104px) var(--pad);background:var(--linen)}
.sv-cta-inner{max-width:680px;margin:0 auto}
