---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import BlogImage from '../BlogImage.astro';
import { insights, fmtLongDate } from '../../i18n/pages/insights';
import { mirrorAlternates, localizePath } from '../../i18n/utils';
import type { Lang } from '../../i18n/config';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = insights[lang];
const p = (path: string) => localizePath(path, lang);

const posts = (await getCollection('blog'))
  .filter(post => post.data.lang === lang)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featured = posts[0];
const rest = posts.slice(1);
---
<Base lang={lang} title={t.seo.title} description={t.seo.description} alternates={mirrorAlternates('/insights')}>

<section class="page-hero">
  <div class="page-hero-inner">
    <p class="page-hero-kick">{t.hero.kick}</p>
    <h1>{t.hero.h1a}<span class="hl">{t.hero.h1accent}</span></h1>
    <p class="page-hero-sub">{t.hero.sub}</p>
  </div>
</section>

{posts.length > 0 ? (
  <section class="ilist">
    <div class="ilist-in">
      <a class="ifeat" href={p(`/insights/${featured.slug}`)}>
        <div class="ifeat-img">
          {featured.data.image && <BlogImage image={featured.data.image} alt={featured.data.title} loading="eager" fetchpriority="high" />}
        </div>
        <div class="ifeat-body">
          <span class="icard-tag">{featured.data.tag}</span>
          <h2 class="ifeat-title">{featured.data.title}</h2>
          <p class="ifeat-ex">{featured.data.excerpt}</p>
          <span class="icard-meta">{fmtLongDate(featured.data.date, lang)}{featured.data.readTime ? ` · ${featured.data.readTime}` : ''}</span>
        </div>
      </a>
      <div class="igrid">
        {rest.map(post => (
          <a class="icard" href={p(`/insights/${post.slug}`)}>
            <div class="icard-img">
              {post.data.image && <BlogImage image={post.data.image} alt={post.data.title} loading="lazy" />}
            </div>
            <span class="icard-tag">{post.data.tag}</span>
            <h3 class="icard-title">{post.data.title}</h3>
            <span class="icard-meta">{fmtLongDate(post.data.date, lang)}{post.data.readTime ? ` · ${post.data.readTime}` : ''}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
) : (
  <div class="blog-empty">
    <h2 class="blog-empty-h">{t.empty.h}</h2>
    <p class="blog-empty-body">{t.empty.body}</p>
  </div>
)}

</Base>

<style>
.ilist{background:var(--cream);padding:clamp(48px,7vw,84px) var(--pad)}
.ilist-in{max-width:1160px;margin:0 auto}
.icard-tag{font-size:12px;font-weight:600;color:var(--chartreuse-deep);letter-spacing:.01em}
.icard-meta{font-size:13px;color:var(--gray)}

.ifeat{display:grid;grid-template-columns:1.15fr .85fr;gap:clamp(24px,4vw,52px);align-items:center;text-decoration:none;margin-bottom:clamp(40px,6vw,72px);padding-bottom:clamp(40px,6vw,72px);border-bottom:1px solid rgba(21,20,15,.12)}
@media(max-width:820px){.ifeat{grid-template-columns:1fr;gap:24px}}
.ifeat-img{aspect-ratio:16/10;overflow:hidden;border-radius:16px;border:1px solid rgba(21,20,15,.1)}
.ifeat-img :global(img){transition:transform .5s ease}
.ifeat:hover .ifeat-img :global(img){transform:scale(1.03)}
.ifeat-body{display:flex;flex-direction:column;gap:14px}
.ifeat-title{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(24px,3.4vw,40px);font-weight:800;letter-spacing:-.03em;line-height:1.05;color:var(--ink);margin:0;text-wrap:balance}
.ifeat-ex{font-size:15.5px;line-height:1.6;color:var(--ink-2);margin:0;max-width:48ch}

.igrid{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(20px,3vw,36px)}
@media(max-width:820px){.igrid{grid-template-columns:1fr 1fr}}
@media(max-width:520px){.igrid{grid-template-columns:1fr}}
.icard{display:flex;flex-direction:column;gap:11px;text-decoration:none}
.icard-img{aspect-ratio:16/10;overflow:hidden;border-radius:12px;border:1px solid rgba(21,20,15,.1);margin-bottom:2px}
.icard-img :global(img){transition:transform .45s ease}
.icard:hover .icard-img :global(img){transform:scale(1.04)}
.icard-title{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:18px;font-weight:700;letter-spacing:-.015em;line-height:1.25;color:var(--ink);margin:0}
.icard-meta{margin-top:2px}

.blog-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:clamp(64px,8vw,96px) var(--pad);text-align:center;background:var(--linen)}
.blog-empty-h{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(22px,3vw,32px);font-weight:800;color:var(--ink);margin-bottom:12px}
.blog-empty-body{font-size:14px;color:var(--gray);max-width:400px;line-height:1.7}
</style>
