---
import Base from '../../layouts/Base.astro';
import { join } from '../../i18n/pages/join';
import { mirrorAlternates } from '../../i18n/utils';
import type { Lang } from '../../i18n/config';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = join[lang];
---
<Base lang={lang} title={t.seo.title} description={t.seo.description} alternates={mirrorAlternates('/join')}>

<section class="page-hero">
  <div class="page-hero-inner">
    <p class="page-hero-kick">{t.hero.kick}</p>
    <h1>{t.hero.h1a}<span class="hl">{t.hero.h1accent}</span></h1>
    <p class="page-hero-sub">{t.hero.sub}</p>
  </div>
</section>

<section class="jn-manifesto">
  <div class="jn-manifesto-inner">
    <div class="jn-manifesto-left">
      <div class="section-eyebrow">{t.manifesto.eyebrow}</div>
      <h2 class="jn-h2">{t.manifesto.h2}</h2>
    </div>
    <div class="jn-manifesto-right">
      {t.manifesto.paragraphs.map(par => <p>{par}</p>)}
    </div>
  </div>
</section>

<section class="jn-values">
  <div class="section-eyebrow">{t.values.eyebrow}</div>
  <div class="jn-values-grid">
    {t.values.cards.map(card => (
      <div class="jn-card"><span class="jn-num">{card.num}</span><div class="jn-card-title">{card.title}</div><div class="jn-card-body">{card.body}</div></div>
    ))}
  </div>
</section>

<section class="jn-cta">
  <div class="jn-cta-inner">
    <h2 class="jn-cta-h2">{t.cta.h2}</h2>
    <span class="jn-cta-sub">{t.cta.sub}</span>
    <a class="btn-primary" href="#contact">{t.cta.button}</a>
    <a class="jn-cta-email" href="mailto:hello@theb2btinkerers.com">hello@theb2btinkerers.com</a>
  </div>
</section>

</Base>

<style>
.jn-manifesto{padding:clamp(72px,9vw,112px) var(--pad);background:var(--cream)}
.jn-manifesto-inner{display:grid;grid-template-columns:1fr 1fr;gap:clamp(36px,6vw,88px);align-items:start}
@media(max-width:760px){.jn-manifesto-inner{grid-template-columns:1fr}}
.jn-h2{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(22px,3vw,38px);font-weight:800;letter-spacing:-0.04em;line-height:1.02;color:var(--forest)}
.jn-manifesto-right p{font-size:clamp(14px,1.6vw,16px);line-height:1.9;color:rgba(26,26,26,.65);margin-bottom:22px}
.jn-manifesto-right p:last-child{margin-bottom:0}
.jn-values{padding:clamp(72px,9vw,112px) var(--pad);background:var(--linen)}
.jn-values .section-eyebrow{margin-bottom:clamp(24px,3vw,40px)}
.jn-values-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(21,20,15,.12);border:1px solid rgba(21,20,15,.12);border-radius:14px;overflow:hidden}
@media(max-width:900px){.jn-values-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:480px){.jn-values-grid{grid-template-columns:1fr}}
.jn-card{background:var(--card);padding:clamp(24px,3vw,34px)}
.jn-num{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:34px;font-weight:800;color:var(--chartreuse-deep);display:block;line-height:1;margin-bottom:10px}
.jn-card-title{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(15px,1.9vw,18px);font-weight:800;color:var(--ink);margin-bottom:10px;line-height:1.25}
.jn-card-body{font-size:13.5px;line-height:1.65;color:var(--ink-2)}
.jn-cta{padding:clamp(56px,8vw,104px) var(--pad);background:var(--cream)}
.jn-cta-inner{max-width:680px;margin:0 auto}
.jn-cta-h2{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(26px,4vw,50px);font-weight:800;letter-spacing:-0.04em;line-height:1.0;color:var(--ink);margin-bottom:18px;text-wrap:balance}
.jn-cta-sub{font-size:clamp(14px,1.5vw,16px);line-height:1.7;color:var(--ink-2);margin-bottom:30px;display:block;max-width:52ch}
.jn-cta-email{display:block;font-size:13px;color:var(--gray);margin-top:12px;text-decoration:none}
</style>
