---
import Base from '../../layouts/Base.astro';
import { about } from '../../i18n/pages/about';
import { mirrorAlternates } from '../../i18n/utils';
import type { Lang } from '../../i18n/config';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = about[lang];
---
<Base lang={lang} title={t.seo.title} description={t.seo.description} alternates={mirrorAlternates('/about')}>

<section class="page-hero">
  <div class="page-hero-inner">
    <p class="page-hero-kick">{t.hero.kick}</p>
    <h1>{t.hero.h1a}<span class="hl">{t.hero.h1accent}</span></h1>
  </div>
</section>

<section class="about-manifesto">
  <div class="about-manifesto-inner">
    <div class="about-manifesto-left">
      <div class="section-eyebrow">{t.manifesto.eyebrow}</div>
      <h2 class="about-h2">{t.manifesto.h2}</h2>
    </div>
    <div class="about-manifesto-right">
      {t.manifesto.paragraphs.map(par => <p>{par}</p>)}
    </div>
  </div>
</section>

<section class="about-values">
  <div class="section-eyebrow">{t.values.eyebrow}</div>
  <div class="about-values-grid">
    {t.values.cards.map(card => (
      <div class="value-card"><span class="value-num">{card.num}</span><div class="value-title">{card.title}</div><div class="value-body">{card.body}</div></div>
    ))}
  </div>
</section>

<section class="about-who">
  <div class="about-who-inner">
    <div class="about-who-left">
      <div class="section-eyebrow">{t.who.eyebrow}</div>
      <h2 class="about-h2">{t.who.h2}</h2>
      {t.who.paragraphs.map(par => <p class="about-who-body">{par}</p>)}
    </div>
    <div class="about-who-right">
      <div class="about-fit-card">
        <div class="fit-title">{t.who.fitTitle}</div>
        <ul class="fit-list">
          {t.who.fit.map(item => <li>{item}</li>)}
        </ul>
      </div>
      <div class="about-notfit-card">
        <div class="fit-title">{t.who.notFitTitle}</div>
        <ul class="fit-list">
          {t.who.notFit.map(item => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>

<section class="about-cta">
  <div class="about-cta-inner">
    <h2 class="about-cta-h2">{t.cta.h2}</h2>
    <span class="about-cta-sub">{t.cta.sub}</span>
    <a class="btn-primary" href="mailto:hello@theb2btinkerers.com">{t.cta.button}</a>
    <a class="about-cta-email" href="mailto:hello@theb2btinkerers.com">hello@theb2btinkerers.com</a>
  </div>
</section>

</Base>

<style>
.about-manifesto{padding:clamp(72px,9vw,112px) var(--pad);background:var(--cream)}
.about-manifesto-inner{display:grid;grid-template-columns:1fr 1fr;gap:clamp(36px,6vw,88px);align-items:start}
@media(max-width:760px){.about-manifesto-inner{grid-template-columns:1fr}}
.about-h2{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(22px,3vw,38px);font-weight:800;letter-spacing:-0.04em;line-height:1.02;color:var(--forest)}
.about-manifesto-right p{font-size:clamp(14px,1.6vw,16px);line-height:1.9;color:rgba(26,26,26,.65);margin-bottom:22px}
.about-manifesto-right p:last-child{margin-bottom:0}
.about-values{padding:clamp(56px,8vw,104px) var(--pad);background:var(--linen)}
.about-values .section-eyebrow{margin-bottom:clamp(24px,3vw,40px)}
.about-values-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(21,20,15,.12);border:1px solid rgba(21,20,15,.12);border-radius:14px;overflow:hidden}
@media(max-width:900px){.about-values-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:480px){.about-values-grid{grid-template-columns:1fr}}
.value-card{background:var(--card);padding:clamp(24px,3vw,34px)}
.value-num{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:34px;font-weight:800;color:var(--chartreuse-deep);display:block;line-height:1;margin-bottom:10px}
.value-title{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(15px,1.9vw,18px);font-weight:800;color:var(--ink);margin-bottom:10px;line-height:1.25}
.value-body{font-size:13.5px;line-height:1.65;color:var(--ink-2)}
.about-who{padding:clamp(72px,9vw,112px) var(--pad);background:var(--linen)}
.about-who-inner{display:grid;grid-template-columns:1fr 1fr;gap:clamp(36px,6vw,88px);align-items:start}
@media(max-width:760px){.about-who-inner{grid-template-columns:1fr}}
.about-who-body{font-size:clamp(13px,1.5vw,15px);line-height:1.9;color:var(--gray);margin-bottom:18px}
.about-fit-card{background:var(--card);padding:clamp(24px,3vw,34px);margin-bottom:12px;border:1px solid rgba(21,20,15,.12);border-radius:12px}
.about-notfit-card{background:transparent;padding:clamp(24px,3vw,34px);border:1px solid rgba(21,20,15,.12);border-radius:12px}
.fit-title{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:14px;font-weight:800;margin-bottom:16px}
.about-fit-card .fit-title{color:var(--chartreuse-deep)}
.about-notfit-card .fit-title{color:var(--ink)}
.fit-list{list-style:none;display:flex;flex-direction:column;gap:10px}
.fit-list li{font-size:13px;line-height:1.55;padding-left:18px;position:relative}
.fit-list li::before{content:'→';position:absolute;left:0;font-size:11px}
.about-fit-card .fit-list li{color:var(--ink-2)}
.about-fit-card .fit-list li::before{color:var(--chartreuse-deep)}
.about-notfit-card .fit-list li{color:var(--gray)}
.about-notfit-card .fit-list li::before{color:var(--gray)}
.about-cta{padding:clamp(56px,8vw,104px) var(--pad);background:var(--cream)}
.about-cta-inner{max-width:680px;margin:0 auto}
.about-cta-h2{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(26px,4vw,50px);font-weight:800;letter-spacing:-0.04em;line-height:1.0;color:var(--ink);margin-bottom:18px;text-wrap:balance}
.about-cta-sub{font-size:clamp(14px,1.5vw,16px);line-height:1.7;color:var(--ink-2);margin-bottom:30px;display:block;max-width:52ch}
.about-cta-email{display:block;font-size:13px;color:var(--gray);margin-top:12px;text-decoration:none}
</style>
