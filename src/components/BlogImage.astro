---
import { Image } from 'astro:assets';

interface Props {
  image: ImageMetadata;
  alt: string;
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'low' | 'auto';
}

const { image, alt, loading = 'lazy', fetchpriority } = Astro.props;
---
<Image
  src={image}
  alt={alt}
  width={800}
  height={340}
  format="webp"
  quality={80}
  loading={loading}
  fetchpriority={fetchpriority}
  style="width:100%;height:100%;object-fit:cover;display:block;"
/>
