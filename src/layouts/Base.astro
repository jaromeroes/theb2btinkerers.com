---
import '@fontsource-variable/inter';
import '@fontsource-variable/bricolage-grotesque';
import '../styles/global.css';
import { ui } from '../i18n/ui';
import { htmlLang, langLabels, type Lang } from '../i18n/config';
import { localizePath, toCanonicalPath, mirrorAlternates } from '../i18n/utils';
import { serviceSlugs, serviceNav } from '../i18n/services-nav';

export interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  /** { en, es } paths for hreflang + language switch. es may be null when no translation exists. */
  alternates?: { en: string; es: string | null };
}

const { title, lang = 'en', description, alternates } = Astro.props;
const t = ui[lang];
const desc = description ?? t.site.defaultDescription;

const siteName = t.site.name;
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;

const currentPath = Astro.url.pathname;
const canonicalCurrent = toCanonicalPath(currentPath);
const isActive = (p: string) =>
  p === '/' ? canonicalCurrent === '/' : canonicalCurrent === p || canonicalCurrent.startsWith(p + '/');

// hreflang / canonical — keep trailing slashes consistent with canonical
const slashed = (path: string) => (path.endsWith('/') ? path : path + '/');
const alt = alternates ?? mirrorAlternates(canonicalCurrent);
const canonicalURL = new URL(slashed(currentPath), Astro.site).href;
const enHref = alt.en ? new URL(slashed(alt.en), Astro.site).href : null;
const esHref = alt.es ? new URL(slashed(alt.es), Astro.site).href : null;

const p = (path: string) => localizePath(path, lang);
const langTargets: Record<Lang, string> = {
  en: slashed(lang === 'en' ? currentPath : (alt.en ?? '/')),
  es: slashed(lang === 'es' ? currentPath : (alt.es ?? '/es/')),
};
---
<!DOCTYPE html>
<html lang={htmlLang[lang]}>
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{fullTitle}</title>
  <meta name="description" content={desc}/>
  <link rel="canonical" href={canonicalURL}/>
  {enHref && <link rel="alternate" hreflang="en" href={enHref}/>}
  {esHref && <link rel="alternate" hreflang="es" href={esHref}/>}
  {enHref && <link rel="alternate" hreflang="x-default" href={enHref}/>}
  <meta property="og:title" content={fullTitle}/>
  <meta property="og:description" content={desc}/>
  <meta property="og:site_name" content={siteName}/>
  <meta property="og:locale" content={htmlLang[lang].replace('-', '_')}/>
  <link rel="icon" type="image/x-icon" href="/favicon.ico"/>
  <!-- Preconnect to external origins -->
  <link rel="preconnect" href="https://cloud.umami.is" crossorigin/>
  <link rel="preconnect" href="https://api-gateway.umami.dev" crossorigin/>
  <!-- Preload critical fonts to break the CSS→font chain -->
  <link rel="preload" href="/_astro/inter-latin-wght-normal.Dx4kXJAl.woff2" as="font" type="font/woff2" crossorigin/>
  <link rel="preload" href="/_astro/bricolage-grotesque-latin-wght-normal.DLoelf7F.woff2" as="font" type="font/woff2" crossorigin/>
  <!-- Umami Analytics — cookieless, GDPR-friendly -->
  <script defer src="https://cloud.umami.is/script.js" data-website-id="4b7eeb1c-03ad-4347-ab65-9bcbc445e068"></script>
</head>
<body>

<a class="skip-link" href="#main-content">{t.site.skipToContent}</a>
<nav class="nav" id="main-nav">
  <div class="nav-inner">
    <a class="nav-logo" href={p('/')}><img src="/logo.svg" alt={t.site.logoAlt} class="nav-logo-img" width="99" height="36"/></a>
    <div class="nav-links">
      <div class="nav-dropdown-wrap">
        <a class={`nav-link${isActive('/services') ? ' active' : ''}`} href={p('/services')}>{t.nav.services}</a>
        <div class="nav-dropdown">
          {serviceSlugs.map(slug => (
            <a class="nav-dropdown-link" href={p(`/services/${slug}`)}>{serviceNav[lang][slug].menu}</a>
          ))}
          <a class="nav-dropdown-link nav-dropdown-all" href={p('/services')}>{t.nav.viewAllServices}</a>
        </div>
      </div>
      <a class={`nav-link${isActive('/insights') ? ' active' : ''}`} href={p('/insights')}>{t.nav.insights}</a>
      <a class={`nav-link${isActive('/about') ? ' active' : ''}`} href={p('/about')}>{t.nav.about}</a>
      <a class={`nav-link${isActive('/join') ? ' active' : ''}`} href={p('/join')}>{t.nav.join}</a>
    </div>
    <div class="nav-right">
      <div class="lang-switch" role="group" aria-label={t.nav.langSwitchLabel}>
        <a class={`lang-opt${lang === 'en' ? ' active' : ''}`} href={langTargets.en} hreflang="en" aria-current={lang === 'en' ? 'true' : undefined}>{langLabels.en}</a>
        <span class="lang-sep" aria-hidden="true">/</span>
        <a class={`lang-opt${lang === 'es' ? ' active' : ''}`} href={langTargets.es} hreflang="es" aria-current={lang === 'es' ? 'true' : undefined}>{langLabels.es}</a>
      </div>
      <a class="nav-cta" href="#contact">{t.nav.cta}</a>
    </div>
    <button class="nav-burger" id="nav-burger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="nav-mobile" id="nav-mobile">
    <div class="nav-mobile-services">
      <button class="nav-mobile-link nav-mobile-toggle" id="nav-services-toggle">{t.nav.services} <span class="nav-mobile-chevron">›</span></button>
      <div class="nav-mobile-sub" id="nav-services-sub">
        {serviceSlugs.map(slug => (
          <a class="nav-mobile-sublink" href={p(`/services/${slug}`)}>{serviceNav[lang][slug].menu}</a>
        ))}
        <a class="nav-mobile-sublink" href={p('/services')}>{t.nav.viewAllServices.replace(' →', '')}</a>
      </div>
    </div>
    <a class="nav-mobile-link" href={p('/insights')}>{t.nav.insights}</a>
    <a class="nav-mobile-link" href={p('/about')}>{t.nav.about}</a>
    <a class="nav-mobile-link" href={p('/join')}>{t.nav.joinMobile}</a>
    <div class="nav-mobile-lang">
      <a class={`lang-opt${lang === 'en' ? ' active' : ''}`} href={langTargets.en} hreflang="en">{langLabels.en}</a>
      <span class="lang-sep" aria-hidden="true">/</span>
      <a class={`lang-opt${lang === 'es' ? ' active' : ''}`} href={langTargets.es} hreflang="es">{langLabels.es}</a>
    </div>
    <a class="nav-mobile-cta" href="#contact">{t.nav.cta}</a>
  </div>
</nav>

<main id="main-content">
  <slot/>
</main>

<section class="contact-section" id="contact">
  <div class="contact-inner">
    <div class="contact-left">
      <div class="contact-eyebrow">{t.contact.eyebrow}</div>
      <h2 class="contact-h2">{t.contact.heading}</h2>
      <p class="contact-body">{t.contact.body}</p>
      <div class="contact-direct">
        <span class="contact-or">{t.contact.orEmail}</span>
        <a class="contact-email-link" href="mailto:hello@theb2btinkerers.com">hello@theb2btinkerers.com</a>
      </div>
    </div>
    <div class="contact-right">
      <form class="contact-form" id="contact-form">
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="name">{t.form.nameLabel}</label>
            <input class="form-input" type="text" id="name" name="name" placeholder={t.form.namePlaceholder} required/>
          </div>
          <div class="form-group">
            <label class="form-label" for="company">{t.form.companyLabel}</label>
            <input class="form-input" type="text" id="company" name="company" placeholder={t.form.companyPlaceholder} required/>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label" for="email">{t.form.emailLabel}</label>
          <input class="form-input" type="email" id="email" name="email" placeholder={t.form.emailPlaceholder} required/>
        </div>
        <div class="form-group">
          <label class="form-label" for="message">{t.form.messageLabel}</label>
          <textarea class="form-textarea" id="message" name="message" placeholder={t.form.messagePlaceholder} rows="4" required></textarea>
        </div>
        <!-- Hidden fields: journey + UTM params -->
        <input type="hidden" name="_language" value={lang}/>
        <input type="hidden" name="_journey" id="field-journey"/>
        <input type="hidden" name="_utm_source" id="field-utm-source"/>
        <input type="hidden" name="_utm_medium" id="field-utm-medium"/>
        <input type="hidden" name="_utm_campaign" id="field-utm-campaign"/>
        <input type="hidden" name="_utm_content" id="field-utm-content"/>
        <input type="hidden" name="_utm_term" id="field-utm-term"/>
        <button class="form-submit" type="submit"
          data-label-default={t.form.submit}
          data-label-sending={t.form.sending}
          data-label-sent={t.form.sent}>{t.form.submit}</button>
        <p class="form-disclaimer">{t.form.disclaimer}</p>
        <p class="form-success" id="form-success" style="display:none;">{t.form.success}</p>
        <p class="form-error" id="form-error" style="display:none;">{t.form.error}</p>
      </form>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-top">
      <a class="footer-logo" href={p('/')}><img src="/logo.svg" alt={t.site.logoAlt} class="footer-logo-img" width="88" height="32"/></a>
      <p class="footer-tagline" set:html={t.footer.tagline}></p>
    </div>
    <div class="footer-mid">
      <div class="footer-col">
        <span class="footer-col-label">{t.footer.servicesLabel}</span>
        {serviceSlugs.map(slug => (
          <a class="footer-link" href={p(`/services/${slug}`)}>{serviceNav[lang][slug].footer}</a>
        ))}
      </div>
      <div class="footer-col">
        <span class="footer-col-label">{t.footer.companyLabel}</span>
        <a class="footer-link" href={p('/about')}>{t.footer.about}</a>
        <a class="footer-link" href={p('/insights')}>{t.footer.insights}</a>
        <a class="footer-link" href={p('/join')}>{t.footer.join}</a>
        <a class="footer-link" href="#contact">{t.footer.contact}</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-label">{t.footer.getInTouchLabel}</span>
        <a class="footer-link" href="mailto:hello@theb2btinkerers.com">hello@theb2btinkerers.com</a>
      </div>
    </div>
    <div class="footer-bottom">
      <span class="footer-copy">{t.footer.copyright}</span>
    </div>
  </div>
</footer>

</body>
</html>

<style>
.nav-right{display:flex;align-items:center;gap:clamp(14px,2vw,24px)}
.lang-switch{display:flex;align-items:center;gap:6px}
.lang-opt{font-size:12px;font-weight:700;letter-spacing:.04em;color:rgba(245,240,232,.5);text-decoration:none;transition:color .15s}
.lang-opt:hover{color:var(--cream)}
.lang-opt.active{color:var(--lime)}
.lang-sep{font-size:12px;color:rgba(245,240,232,.3)}
@media(max-width:700px){.nav-right{display:none}}
.nav-mobile-lang{display:flex;align-items:center;gap:8px;padding:16px 0 4px}
.nav-mobile-lang .lang-opt{font-size:14px}
</style>

<script>
/* ── Nav ── */
const nav = document.getElementById('main-nav');
window.addEventListener('scroll', () => {
  nav?.classList.toggle('scrolled', window.scrollY > 20);
}, {passive:true});
document.getElementById('nav-burger')?.addEventListener('click', function() {
  this.classList.toggle('open');
  document.getElementById('nav-mobile')?.classList.toggle('open');
});

/* ── Mobile services sub-menu ── */
document.getElementById('nav-services-toggle')?.addEventListener('click', function() {
  this.classList.toggle('open');
  document.getElementById('nav-services-sub')?.classList.toggle('open');
});

/* ── Session journey tracking ── */
(function() {
  const key = 'tb2bt_journey';
  const pages = JSON.parse(sessionStorage.getItem(key) || '[]');
  const current = window.location.pathname;
  if (pages[pages.length - 1] !== current) {
    pages.push(current);
    sessionStorage.setItem(key, JSON.stringify(pages));
  }
})();

/* ── UTM capture (persist for the session) ── */
(function() {
  const utmKey = 'tb2bt_utm';
  const params = new URLSearchParams(window.location.search);
  const utmFields = ['utm_source','utm_medium','utm_campaign','utm_content','utm_term'];
  const hasUtm = utmFields.some(f => params.has(f));
  if (hasUtm) {
    const utmData = {};
    utmFields.forEach(f => { if (params.get(f)) utmData[f] = params.get(f); });
    sessionStorage.setItem(utmKey, JSON.stringify(utmData));
  }
})();

/* ── Async form submission + Umami event ── */
(function() {
  const form = document.getElementById('contact-form');
  if (!form) return;

  const btn = form.querySelector('.form-submit');
  const labelDefault = btn?.dataset.labelDefault || 'Send message →';
  const labelSending = btn?.dataset.labelSending || 'Sending...';
  const labelSent = btn?.dataset.labelSent || 'Sent ✓';

  form.addEventListener('submit', async function(e) {
    e.preventDefault();

    const successEl = document.getElementById('form-success');
    const errorEl = document.getElementById('form-error');

    /* Inject journey and UTM data into hidden fields */
    const journey = JSON.parse(sessionStorage.getItem('tb2bt_journey') || '[]');
    document.getElementById('field-journey').value = journey.join(' → ');

    const utmData = JSON.parse(sessionStorage.getItem('tb2bt_utm') || '{}');
    document.getElementById('field-utm-source').value = utmData.utm_source || '';
    document.getElementById('field-utm-medium').value = utmData.utm_medium || '';
    document.getElementById('field-utm-campaign').value = utmData.utm_campaign || '';
    document.getElementById('field-utm-content').value = utmData.utm_content || '';
    document.getElementById('field-utm-term').value = utmData.utm_term || '';

    btn.disabled = true;
    btn.textContent = labelSending;
    successEl.style.display = 'none';
    errorEl.style.display = 'none';

    try {
      const res = await fetch('https://formspree.io/f/mbdprobk', {
        method: 'POST',
        headers: { 'Accept': 'application/json' },
        body: new FormData(form)
      });

      if (res.ok) {
        form.reset();
        successEl.style.display = 'block';
        btn.textContent = labelSent;

        /* Fire Umami conversion event */
        if (typeof umami !== 'undefined') {
          umami.track('contact-form-submitted', {
            source: utmData.utm_source || 'direct',
            journey_length: journey.length
          });
        }
      } else {
        throw new Error('Form submission failed');
      }
    } catch (err) {
      errorEl.style.display = 'block';
      btn.disabled = false;
      btn.textContent = labelDefault;
    }
  });
})();
</script>
