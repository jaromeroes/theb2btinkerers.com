---
import '@fontsource-variable/inter';
import '@fontsource-variable/bricolage-grotesque';
import '../styles/global.css';
export interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
}
const {
  title,
  description = 'B2B Marketing Strategy Consultancy. We help B2B tech and industrial companies get more from marketing — without spending more.',
  canonicalURL = Astro.url.href,
} = Astro.props;
const siteName = 'The B2B Tinkerers';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{fullTitle}</title>
  <meta name="description" content={description}/>
  <link rel="canonical" href={canonicalURL}/>
  <meta property="og:title" content={fullTitle}/>
  <meta property="og:description" content={description}/>
  <meta property="og:site_name" content={siteName}/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <!-- Umami Analytics — cookieless, GDPR-friendly -->
  <script defer src="https://cloud.umami.is/script.js" data-website-id="4b7eeb1c-03ad-4347-ab65-9bcbc445e068"></script>
</head>
<body>

<a class="skip-link" href="#main-content">Skip to content</a>
<nav class="nav" id="main-nav">
  <div class="nav-inner">
    <a class="nav-logo" href="/"><img src="/logo.svg" alt="The B2B Tinkerers" class="nav-logo-img"/></a>
    <div class="nav-links">
      <a class={`nav-link${currentPath==='/'?'':''}`} href="/#services">Services</a>
      <a class={`nav-link${currentPath==='/'?'':''}`} href="/#method">Method</a>
      <a class={`nav-link${currentPath.startsWith('/insights')?' active':''}`} href="/insights">Insights</a>
      <a class={`nav-link${currentPath==='/about'?' active':''}`} href="/about">About</a>
    </div>
    <a class="nav-cta" href="/#contact">Book a call →</a>
    <button class="nav-burger" id="nav-burger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="nav-mobile" id="nav-mobile">
    <a class="nav-mobile-link" href="/#services">Services</a>
    <a class="nav-mobile-link" href="/#method">Method</a>
    <a class="nav-mobile-link" href="/insights">Insights</a>
    <a class="nav-mobile-link" href="/about">About</a>
    <a class="nav-mobile-cta" href="mailto:hello@theb2btinkerers.com">Book a discovery call →</a>
  </div>
</nav>

<main id="main-content">
  <slot/>
</main>

<section class="contact-section" id="contact">
  <div class="contact-inner">
    <div class="contact-left">
      <div class="contact-eyebrow">Work with us</div>
      <h2 class="contact-h2">Ready to talk?</h2>
      <p class="contact-body">Tell us a bit about your company and what you're trying to solve. We'll get back to you within 24 hours.</p>
      <div class="contact-direct">
        <span class="contact-or">Or email us directly</span>
        <a class="contact-email-link" href="mailto:hello@theb2btinkerers.com">hello@theb2btinkerers.com</a>
      </div>
    </div>
    <div class="contact-right">
      <form class="contact-form" id="contact-form">
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="name">Your name</label>
            <input class="form-input" type="text" id="name" name="name" placeholder="Jane Smith" required/>
          </div>
          <div class="form-group">
            <label class="form-label" for="company">Company</label>
            <input class="form-input" type="text" id="company" name="company" placeholder="Acme B2B" required/>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label" for="email">Work email</label>
          <input class="form-input" type="email" id="email" name="email" placeholder="jane@company.com" required/>
        </div>
        <div class="form-group">
          <label class="form-label" for="message">What are you trying to solve?</label>
          <textarea class="form-textarea" id="message" name="message" placeholder="Tell us about your current situation and what you're looking for..." rows="4" required></textarea>
        </div>
        <!-- Hidden fields: journey + UTM params -->
        <input type="hidden" name="_journey" id="field-journey"/>
        <input type="hidden" name="_utm_source" id="field-utm-source"/>
        <input type="hidden" name="_utm_medium" id="field-utm-medium"/>
        <input type="hidden" name="_utm_campaign" id="field-utm-campaign"/>
        <input type="hidden" name="_utm_content" id="field-utm-content"/>
        <input type="hidden" name="_utm_term" id="field-utm-term"/>
        <button class="form-submit" type="submit">Send message →</button>
        <p class="form-disclaimer">We'll respond within 24 hours. No spam, no pitch decks.</p>
        <p class="form-success" id="form-success" style="display:none;">Message sent. We'll be in touch shortly.</p>
        <p class="form-error" id="form-error" style="display:none;">Something went wrong. Please try emailing us directly.</p>
      </form>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-top">
      <a class="footer-logo" href="/"><img src="/logo.svg" alt="The B2B Tinkerers" class="footer-logo-img"/></a>
      <p class="footer-tagline">Senior B2B marketing strategy,<br/>without the agency overhead.</p>
    </div>
    <div class="footer-mid">
      <div class="footer-col">
        <span class="footer-col-label">Services</span>
        <a class="footer-link" href="/#services">Marketing Audit</a>
        <a class="footer-link" href="/#services">Brand Strategy</a>
        <a class="footer-link" href="/#services">Go-To-Market</a>
        <a class="footer-link" href="/#services">Fractional CMO</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-label">Company</span>
        <a class="footer-link" href="/about">About</a>
        <a class="footer-link" href="/insights">Insights</a>
        <a class="footer-link" href="/#contact">Contact</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-label">Get in touch</span>
        <a class="footer-link" href="mailto:hello@theb2btinkerers.com">hello@theb2btinkerers.com</a>
      </div>
    </div>
    <div class="footer-bottom">
      <span class="footer-copy">© 2026 The B2B Tinkerers. All rights reserved.</span>
    </div>
  </div>
</footer>

</body>
</html>

<script>
/* ── Nav ── */
const nav = document.getElementById('main-nav');
window.addEventListener('scroll', () => {
  nav?.classList.toggle('scrolled', window.scrollY > 20);
}, {passive:true});
document.getElementById('nav-burger')?.addEventListener('click', function() {
  this.classList.toggle('open');
  document.getElementById('nav-mobile')?.classList.toggle('open');
});

/* ── Session journey tracking ── */
(function() {
  const key = 'tb2bt_journey';
  const pages = JSON.parse(sessionStorage.getItem(key) || '[]');
  const current = window.location.pathname;
  if (pages[pages.length - 1] !== current) {
    pages.push(current);
    sessionStorage.setItem(key, JSON.stringify(pages));
  }
})();

/* ── UTM capture (persist for the session) ── */
(function() {
  const utmKey = 'tb2bt_utm';
  const params = new URLSearchParams(window.location.search);
  const utmFields = ['utm_source','utm_medium','utm_campaign','utm_content','utm_term'];
  const hasUtm = utmFields.some(f => params.has(f));
  if (hasUtm) {
    const utmData = {};
    utmFields.forEach(f => { if (params.get(f)) utmData[f] = params.get(f); });
    sessionStorage.setItem(utmKey, JSON.stringify(utmData));
  }
})();

/* ── Async form submission + Umami event ── */
(function() {
  const form = document.getElementById('contact-form');
  if (!form) return;

  form.addEventListener('submit', async function(e) {
    e.preventDefault();

    const btn = form.querySelector('.form-submit');
    const successEl = document.getElementById('form-success');
    const errorEl = document.getElementById('form-error');

    /* Inject journey and UTM data into hidden fields */
    const journey = JSON.parse(sessionStorage.getItem('tb2bt_journey') || '[]');
    document.getElementById('field-journey').value = journey.join(' → ');

    const utmData = JSON.parse(sessionStorage.getItem('tb2bt_utm') || '{}');
    document.getElementById('field-utm-source').value = utmData.utm_source || '';
    document.getElementById('field-utm-medium').value = utmData.utm_medium || '';
    document.getElementById('field-utm-campaign').value = utmData.utm_campaign || '';
    document.getElementById('field-utm-content').value = utmData.utm_content || '';
    document.getElementById('field-utm-term').value = utmData.utm_term || '';

    btn.disabled = true;
    btn.textContent = 'Sending...';
    successEl.style.display = 'none';
    errorEl.style.display = 'none';

    try {
      const res = await fetch('https://formspree.io/f/xjgedjdv', {
        method: 'POST',
        headers: { 'Accept': 'application/json' },
        body: new FormData(form)
      });

      if (res.ok) {
        form.reset();
        successEl.style.display = 'block';
        btn.textContent = 'Sent ✓';

        /* Fire Umami conversion event */
        if (typeof umami !== 'undefined') {
          umami.track('contact-form-submitted', {
            source: utmData.utm_source || 'direct',
            journey_length: journey.length
          });
        }
      } else {
        throw new Error('Form submission failed');
      }
    } catch (err) {
      errorEl.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Send message →';
    }
  });
})();
</script>
