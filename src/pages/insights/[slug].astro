<script>
const links = document.querySelectorAll('.toc-link');
const headingEls: Element[] = [];
links.forEach(link => {
  const target = link.getAttribute('data-target');
  if (target) { const el = document.getElementById(target); if (el) headingEls.push(el); }
});
function updateTOC() {
  const scrollY = window.scrollY + 120;
  let current = '';
  for (const el of headingEls) {
    if ((el as HTMLElement).getBoundingClientRect().top + window.scrollY <= scrollY) current = el.id;
  }
  links.forEach(link => { link.classList.toggle('active', link.getAttribute('data-target') === current); });
}
window.addEventListener('scroll', updateTOC, { passive: true });
updateTOC();
</script>

<style>
.art-hero{padding:calc(68px + clamp(44px,6vw,72px)) var(--pad) 0;background:var(--forest);position:relative;overflow:hidden}
.art-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 80% 20%,rgba(212,232,74,0.06) 0%,transparent 55%);pointer-events:none}
.art-hero-inner{max-width:720px;padding-bottom:clamp(44px,6vw,72px);position:relative;z-index:1}
.art-back{font-size:11px;font-weight:600;color:rgba(245,240,232,.35);text-decoration:none;margin-bottom:24px;display:block;transition:color .15s}
.art-back:hover{color:rgba(245,240,232,.7)}
.art-tag-label{font-size:9px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--lime);display:inline-block;margin-bottom:16px;opacity:.8}
.art-h1{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(28px,4.5vw,54px);font-weight:800;letter-spacing:-0.04em;line-height:.97;color:var(--cream);margin-bottom:18px}
.art-deck{font-size:clamp(15px,1.9vw,18px);line-height:1.7;color:rgba(245,240,232,.55);max-width:580px;margin-bottom:28px}
.art-meta{display:flex;align-items:center;gap:20px;flex-wrap:wrap;padding-top:20px;border-top:1px solid rgba(255,255,255,.08)}
.art-author{display:flex;align-items:center;gap:10px}
