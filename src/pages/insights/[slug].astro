.art-author-name{font-size:12px;font-weight:600;color:rgba(245,240,232,.6)}
.art-date,.art-readtime{font-size:11px;color:rgba(245,240,232,.3)}
.art-readtime::before{content:'·';margin-right:8px}
.art-img-band{background:var(--mid);height:clamp(160px,22vw,280px);overflow:hidden}
.art-page-wrap{background:var(--cream);padding:0 var(--pad)}
.art-layout{display:grid;grid-template-columns:220px 1fr;gap:0;max-width:1100px;margin:0 auto}
@media(max-width:900px){.art-layout{grid-template-columns:1fr}}
.art-toc{padding:clamp(44px,6vw,72px) 0}
@media(max-width:900px){.art-toc{display:none}}
.art-toc-inner{position:sticky;top:calc(68px + 32px);padding-right:32px;border-right:1px solid rgba(28,74,58,0.1)}
.toc-label{font-size:9px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:rgba(28,74,58,0.4);margin-bottom:16px;display:block}
.toc-list{list-style:none;display:flex;flex-direction:column;gap:2px;margin-bottom:24px}
.toc-link{display:flex;align-items:flex-start;gap:10px;font-size:12px;line-height:1.45;color:rgba(28,74,58,0.45);text-decoration:none;padding:6px 0;transition:color .15s;position:relative}
.toc-link::before{content:'';flex-shrink:0;width:2px;min-height:14px;background:transparent;border-radius:1px;transition:background .2s;margin-top:1px}
.toc-link:hover{color:rgba(28,74,58,0.75)}
.toc-link.active{color:var(--forest);font-weight:600}
.toc-link.active::before{background:var(--lime)}
