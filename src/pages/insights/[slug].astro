---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---
<Base title={post.data.title} description={post.data.excerpt}>

<article class="article">
  <div class="article-hero">
    <div class="article-hero-inner">
      <a class="article-back" href="/insights">← All articles</a>
      <span class="article-tag">{post.data.tag}</span>
      <h1 class="article-h1">{post.data.title}</h1>
      <div class="article-meta">
        <span>{post.data.date.toLocaleDateString('en-GB',{day:'numeric',month:'long',year:'numeric'})}</span>
        <span class="article-meta-sep">·</span>
        <span>{post.data.readTime}</span>
      </div>
    </div>
  </div>
  <div class="article-body">
    <div class="article-content">
      <Content/>
    </div>
    <div class="article-cta-box">
      <h3 class="article-cta-h">Found this useful?</h3>
      <p class="article-cta-body">We write about B2B marketing strategy, alignment, and growth. If you're dealing with similar challenges, we'd be happy to talk.</p>
      <a class="btn-primary" href="/#contact">Get in touch →</a>
    </div>
  </div>
</article>

</Base>

<style>
.article-hero{padding:calc(68px + clamp(44px,6vw,72px)) var(--pad) clamp(44px,6vw,64px);background:var(--forest);position:relative;overflow:hidden}
.article-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 70% 20%,rgba(212,232,74,0.07) 0%,transparent 55%);pointer-events:none}
.article-hero-inner{max-width:720px;position:relative;z-index:1}
.article-back{font-size:12px;font-weight:600;color:rgba(245,240,232,.4);text-decoration:none;display:inline-block;margin-bottom:24px;transition:color .15s}
.article-back:hover{color:rgba(245,240,232,.8)}
.article-tag{font-size:9px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--lime);opacity:.7;display:block;margin-bottom:16px}
.article-h1{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(28px,4.5vw,54px);font-weight:800;letter-spacing:-0.04em;line-height:.97;color:var(--cream);margin-bottom:20px}
.article-meta{font-size:12px;color:rgba(245,240,232,.3);display:flex;gap:8px;align-items:center}
.article-meta-sep{opacity:.4}
.article-body{max-width:720px;margin:0 auto;padding:clamp(44px,6vw,72px) var(--pad)}
.article-content{font-size:clamp(15px,1.7vw,17px);line-height:1.85;color:rgba(26,26,26,.78)}
.article-content h2{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(20px,2.5vw,30px);font-weight:800;letter-spacing:-0.03em;color:var(--forest);margin:2.5em 0 .8em;line-height:1.1}
.article-content p{margin-bottom:1.4em}
.article-content strong{font-weight:700;color:var(--forest)}
.article-content ul,.article-content ol{padding-left:1.4em;margin-bottom:1.4em}
.article-content li{margin-bottom:.5em}
.article-content hr{border:none;border-top:1px solid rgba(28,74,58,.12);margin:2.5em 0}
.article-content em{color:rgba(26,26,26,.55);font-style:italic}
.article-cta-box{margin-top:clamp(44px,6vw,72px);background:var(--forest);padding:clamp(28px,4vw,48px);border-radius:2px}
.article-cta-h{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(20px,2.5vw,28px);font-weight:800;color:var(--cream);margin-bottom:12px}
.article-cta-body{font-size:14px;line-height:1.75;color:rgba(245,240,232,.45);margin-bottom:24px}
</style>
