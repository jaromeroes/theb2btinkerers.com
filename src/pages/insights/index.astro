---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base title="Insights" description="Strategy, alignment, GTM, AI, and the things most B2B consultancies won't admit out loud.">

<section class="blog-hero">
  <div class="blog-hero-inner">
    <div class="blog-hero-eyebrow">Insights & thinking</div>
    <h1 class="blog-hero-h1">What we know.<br/>What we've learned.<br/>What we won't say<br/>in a sales pitch.</h1>
    <p class="blog-hero-sub">Strategy, alignment, GTM, AI, and the things most B2B consultancies won't admit out loud.</p>
  </div>
</section>

{posts.length > 0 ? (
  <section class="blog-grid-section">
    <div class="blog-grid">
      {posts.map((post, i) => (
        <a class={`blog-list-card${i === 0 ? ' blc-featured' : ''}`} href={`/insights/${post.slug}`}>
          <div class="blc-illo">
            <svg viewBox="0 0 360 120" fill="none" width="100%" height="100%">
              <rect width="360" height="120" fill={i === 0 ? "#1C4A3A" : i % 2 === 0 ? "#E8E3D8" : "#2A6B54"}/>
              {i === 0 && <>
                <circle cx="180" cy="60" r="100" fill="rgba(42,107,84,0.3)"/>
                <rect x="60" y="75" width="14" height="30" rx="2" fill="rgba(245,240,232,0.15)"/>
                <rect x="80" y="60" width="14" height="45" rx="2" fill="rgba(245,240,232,0.2)"/>
                <rect x="100" y="45" width="14" height="60" rx="2" fill="rgba(245,240,232,0.15)"/>
                <rect x="120" y="30" width="14" height="75" rx="2" fill="#D4E84A"/>
                <text x="175" y="72" font-family="Bricolage Grotesque,sans-serif" font-size="32" font-weight="800" fill="rgba(212,232,74,0.85)" letter-spacing="-2">65%</text>
                <text x="176" y="85" font-family="Inter,sans-serif" font-size="8" font-weight="700" fill="rgba(212,232,74,0.5)" letter-spacing="2">MISALIGNED</text>
              </>}
              {i === 1 && <>
                <rect x="40" y="20" width="120" height="80" rx="4" fill="#F5F0E8" stroke="rgba(28,74,58,0.1)" stroke-width="1"/>
                <rect x="52" y="34" width="70" height="6" rx="2" fill="rgba(28,74,58,0.2)"/>
                <rect x="52" y="46" width="90" height="4" rx="2" fill="rgba(28,74,58,0.1)"/>
                <rect x="52" y="56" width="80" height="4" rx="2" fill="rgba(28,74,58,0.1)"/>
                <rect x="52" y="70" width="50" height="16" rx="2" fill="#1C4A3A"/>
                <text x="57" y="82" font-family="Inter,sans-serif" font-size="7" font-weight="700" fill="#D4E84A" letter-spacing="0.5">FRACTIONAL</text>
                <line x1="176" y1="40" x2="196" y2="40" stroke="rgba(42,107,84,0.3)" stroke-width="1.5" stroke-dasharray="3 2"/>
                <line x1="176" y1="60" x2="196" y2="60" stroke="rgba(42,107,84,0.2)" stroke-width="1.5" stroke-dasharray="3 2"/>
                <line x1="176" y1="80" x2="196" y2="80" stroke="rgba(42,107,84,0.15)" stroke-width="1.5" stroke-dasharray="3 2"/>
                <rect x="206" y="20" width="110" height="80" rx="4" fill="#1C4A3A"/>
                <text x="261" y="58" font-family="Bricolage Grotesque,sans-serif" font-size="24" font-weight="800" fill="#D4E84A" text-anchor="middle">CMO</text>
                <rect x="228" y="68" width="66" height="3" rx="1" fill="rgba(212,232,74,0.3)"/>
                <rect x="228" y="76" width="50" height="3" rx="1" fill="rgba(212,232,74,0.18)"/>
              </>}
              {i >= 2 && <>
                <circle cx="100" cy="60" r="18" fill="rgba(212,232,74,0.15)" stroke="rgba(212,232,74,0.35)" stroke-width="1.5"/>
                <circle cx="200" cy="30" r="14" fill="rgba(212,232,74,0.2)" stroke="rgba(212,232,74,0.4)" stroke-width="1.5"/>
                <circle cx="280" cy="60" r="18" fill="rgba(212,232,74,0.15)" stroke="rgba(212,232,74,0.3)" stroke-width="1.5"/>
                <circle cx="150" cy="90" r="12" fill="rgba(212,232,74,0.1)" stroke="rgba(212,232,74,0.25)" stroke-width="1.5"/>
                <circle cx="240" cy="90" r="12" fill="rgba(212,232,74,0.1)" stroke="rgba(212,232,74,0.25)" stroke-width="1.5"/>
                <line x1="117" y1="55" x2="186" y2="36" stroke="rgba(212,232,74,0.25)" stroke-width="1"/>
                <line x1="214" y1="36" x2="263" y2="55" stroke="rgba(212,232,74,0.25)" stroke-width="1"/>
                <text x="94" y="64" font-family="Inter,sans-serif" font-size="8" font-weight="700" fill="#D4E84A" text-anchor="middle">AI</text>
                <text x="200" y="34" font-family="Inter,sans-serif" font-size="7" font-weight="700" fill="#D4E84A" text-anchor="middle">MKT</text>
                <text x="280" y="64" font-family="Inter,sans-serif" font-size="7" font-weight="700" fill="#D4E84A" text-anchor="middle">REV</text>
              </>}
            </svg>
          </div>
          <span class="blc-tag">{post.data.tag}</span>
          <div class="blc-title">{post.data.title}</div>
          <div class="blc-excerpt">{post.data.excerpt}</div>
          <div class="blc-meta">
            <span class="blc-date">{post.data.date.toLocaleDateString('en-GB',{day:'numeric',month:'long',year:'numeric'})} · {post.data.readTime}</span>
            <span class="blc-arrow">→</span>
          </div>
        </a>
      ))}
    </div>
  </section>
) : (
  <div class="blog-empty">
    <div class="blog-empty-icon">✍️</div>
    <h2 class="blog-empty-h">Articles coming soon.</h2>
    <p class="blog-empty-body">We're writing the first batch of articles now. No filler, no SEO fluff — just the honest thinking we wish we'd read earlier in our careers.</p>
  </div>
)}

</Base>

<style>
.blog-hero{padding:calc(68px + clamp(44px,6vw,72px)) var(--pad) clamp(44px,6vw,64px);background:var(--forest);position:relative;overflow:hidden}
.blog-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 70% 30%,rgba(212,232,74,0.06) 0%,transparent 55%);pointer-events:none}
.blog-hero-inner{max-width:660px;position:relative;z-index:1}
.blog-hero-eyebrow{font-size:9px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:var(--lime);opacity:.6;display:flex;align-items:center;gap:10px;margin-bottom:18px}
.blog-hero-eyebrow::before{content:'';display:block;width:18px;height:1px;background:var(--lime)}
.blog-hero-h1{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(28px,4.5vw,56px);font-weight:800;letter-spacing:-0.04em;line-height:.96;color:var(--cream);margin-bottom:16px}
.blog-hero-sub{font-size:clamp(13px,1.6vw,16px);color:rgba(245,240,232,.45);line-height:1.8;max-width:500px}
.blog-grid-section{padding:clamp(44px,6vw,72px) var(--pad);background:var(--cream)}
.blog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
@media(max-width:900px){.blog-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:560px){.blog-grid{grid-template-columns:1fr}}
.blog-list-card{background:var(--linen);text-decoration:none;padding:clamp(22px,3vw,32px);display:flex;flex-direction:column;gap:10px;transition:background .2s}
.blog-list-card:hover{background:#ddd8ce}
.blog-list-card:first-child{background:var(--forest)}
.blog-list-card:first-child:hover{background:#235e48}
.blc-tag{font-size:9px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--lime)}
.blog-list-card:not(:first-child) .blc-tag{color:var(--mid)}
.blc-title{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(15px,2vw,20px);font-weight:700;line-height:1.2;color:var(--cream);flex:1}
.blog-list-card:not(:first-child) .blc-title{color:var(--forest)}
.blc-excerpt{font-size:12.5px;line-height:1.7;color:rgba(245,240,232,.45)}
.blog-list-card:not(:first-child) .blc-excerpt{color:rgba(28,74,58,.55)}
.blc-meta{display:flex;align-items:center;justify-content:space-between;padding-top:14px;border-top:1px solid rgba(245,240,232,.08);margin-top:auto}
.blog-list-card:not(:first-child) .blc-meta{border-top-color:rgba(28,74,58,.1)}
.blc-date{font-size:10px;color:rgba(245,240,232,.3)}
.blog-list-card:not(:first-child) .blc-date{color:rgba(28,74,58,.35)}
.blc-arrow{font-size:14px;color:var(--lime);transition:transform .2s}
.blog-list-card:not(:first-child) .blc-arrow{color:var(--forest);opacity:.5}
.blog-list-card:hover .blc-arrow{transform:translateX(4px)}
.blc-illo{width:100%;overflow:hidden;flex-shrink:0;aspect-ratio:16/6}
.blog-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:clamp(64px,8vw,96px) var(--pad);text-align:center;background:var(--linen)}
.blog-empty-icon{font-size:48px;margin-bottom:24px;opacity:.4}
.blog-empty-h{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(22px,3vw,32px);font-weight:800;color:var(--forest);margin-bottom:12px}
.blog-empty-body{font-size:14px;color:var(--gray);max-width:400px;line-height:1.7}
</style>
