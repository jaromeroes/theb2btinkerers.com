---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base title="Insights" description="Strategy, alignment, GTM, AI, and the things most B2B consultancies won't admit out loud.">

<section class="blog-hero">
  <div class="blog-hero-inner">
    <div class="blog-hero-eyebrow">Insights & thinking</div>
    <h1 class="blog-hero-h1">What we know.<br/>What we've learned.<br/>What we won't say<br/>in a sales pitch.</h1>
    <p class="blog-hero-sub">Strategy, alignment, GTM, AI, and the things most B2B consultancies won't admit out loud.</p>
  </div>
</section>

{posts.length > 0 ? (
  <section class="blog-grid-section">
    <div class="blog-grid">
      {posts.map((post, i) => (
        <a class={`blog-list-card${i === 0 ? ' blc-featured' : ''}`} href={`/insights/${post.slug}`}>
          <div class="blc-illo">
            {post.slug === '65-percent-b2b-marketing-budgets' ? (
              <svg viewBox="0 0 360 120" fill="none" width="100%" height="100%">
                <rect width="360" height="120" fill="#1C4A3A"/>
                <line x1="0" y1="30" x2="360" y2="30" stroke="rgba(245,240,232,0.025)" stroke-width="1"/>
                <line x1="0" y1="60" x2="360" y2="60" stroke="rgba(245,240,232,0.025)" stroke-width="1"/>
                <line x1="0" y1="90" x2="360" y2="90" stroke="rgba(245,240,232,0.025)" stroke-width="1"/>
                <text x="-2" y="108" font-family="Bricolage Grotesque,sans-serif" font-size="96" font-weight="800" fill="rgba(212,232,74,0.05)" letter-spacing="-7">65</text>
                <rect x="16" y="82" width="16" height="26" rx="1" fill="rgba(245,240,232,0.08)"/>
                <rect x="36" y="68" width="16" height="40" rx="1" fill="rgba(245,240,232,0.11)"/>
                <rect x="56" y="52" width="16" height="56" rx="1" fill="rgba(245,240,232,0.09)"/>
                <rect x="76" y="38" width="16" height="70" rx="1" fill="rgba(245,240,232,0.07)"/>
                <rect x="96" y="46" width="16" height="62" rx="1" fill="#D4E84A"/>
                <polyline points="24,90 44,76 64,60 84,44 104,52" stroke="rgba(212,232,74,0.4)" stroke-width="1.5" fill="none"/>
                <circle cx="104" cy="52" r="3" fill="#D4E84A"/>
                <rect x="142" y="12" width="100" height="96" rx="2" fill="rgba(255,255,255,0.04)" stroke="rgba(212,232,74,0.1)" stroke-width="1"/>
                <text x="192" y="60" font-family="Bricolage Grotesque,sans-serif" font-size="36" font-weight="800" fill="#D4E84A" text-anchor="middle" letter-spacing="-2">65%</text>
                <text x="192" y="76" font-family="Inter,sans-serif" font-size="7" font-weight="600" fill="rgba(245,240,232,0.4)" text-anchor="middle" letter-spacing=".8">OF B2B BUDGETS</text>
                <text x="192" y="90" font-family="Inter,sans-serif" font-size="7" fill="rgba(245,240,232,0.22)" text-anchor="middle">Forrester 2024</text>
                <rect x="258" y="12" width="88" height="44" rx="2" fill="rgba(212,232,74,0.06)"/>
                <text x="302" y="34" font-family="Bricolage Grotesque,sans-serif" font-size="20" font-weight="800" fill="rgba(212,232,74,0.5)" text-anchor="middle" letter-spacing="-1">$1T</text>
                <text x="302" y="47" font-family="Inter,sans-serif" font-size="7" font-weight="600" fill="rgba(245,240,232,0.28)" text-anchor="middle">lost / year</text>
                <rect x="258" y="64" width="88" height="44" rx="2" fill="rgba(42,107,84,0.3)"/>
                <text x="302" y="86" font-family="Bricolage Grotesque,sans-serif" font-size="20" font-weight="800" fill="rgba(212,232,74,0.45)" text-anchor="middle" letter-spacing="-1">+27%</text>
                <text x="302" y="99" font-family="Inter,sans-serif" font-size="7" font-weight="600" fill="rgba(245,240,232,0.25)" text-anchor="middle">profit growth</text>
              </svg>
            ) : post.slug === 'fractional-cmo-competitive-advantage' ? (
              <svg viewBox="0 0 360 120" fill="none" width="100%" height="100%">
                <rect width="360" height="120" fill="#1C4A3A"/>
                <text x="-2" y="108" font-family="Bricolage Grotesque,sans-serif" font-size="96" font-weight="800" fill="rgba(212,232,74,0.04)" letter-spacing="-7">CMO</text>
                <rect x="16" y="16" width="130" height="88" rx="3" fill="rgba(28,50,38,0.7)" stroke="rgba(245,240,232,0.07)" stroke-width="1"/>
                <text x="81" y="44" font-family="Inter,sans-serif" font-size="7" font-weight="700" fill="rgba(245,240,232,0.28)" text-anchor="middle" letter-spacing="1">FULL-TIME</text>
                <circle cx="81" cy="66" r="16" fill="rgba(245,240,232,0.1)"/>
                <line x1="58" y1="44" x2="104" y2="96" stroke="rgba(220,60,60,0.35)" stroke-width="1.5"/>
                <line x1="104" y1="44" x2="58" y2="96" stroke="rgba(220,60,60,0.35)" stroke-width="1.5"/>
                <text x="190" y="56" font-family="Bricolage Grotesque,sans-serif" font-size="12" font-weight="800" fill="rgba(212,232,74,0.25)" text-anchor="middle">VS</text>
                <rect x="210" y="8" width="134" height="104" rx="3" fill="rgba(212,232,74,0.12)" stroke="rgba(212,232,74,0.28)" stroke-width="1.5"/>
                <text x="277" y="36" font-family="Inter,sans-serif" font-size="7" font-weight="700" fill="rgba(212,232,74,0.6)" text-anchor="middle" letter-spacing="1.2">FRACTIONAL CMO</text>
                <circle cx="277" cy="66" r="22" fill="rgba(212,232,74,0.18)" stroke="rgba(212,232,74,0.3)" stroke-width="1.5"/>
                <text x="277" y="71" font-family="Bricolage Grotesque,sans-serif" font-size="16" font-weight="800" fill="#D4E84A" text-anchor="middle">CMO</text>
                <text x="277" y="98" font-family="Inter,sans-serif" font-size="7" fill="rgba(212,232,74,0.45)" text-anchor="middle">outside-in · strategic</text>
              </svg>
            ) : (
              <svg viewBox="0 0 360 120" fill="none" width="100%" height="100%">
                <rect width="360" height="120" fill="#1C4A3A"/>
                <text x="-2" y="108" font-family="Bricolage Grotesque,sans-serif" font-size="80" font-weight="800" fill="rgba(212,232,74,0.04)" letter-spacing="-5">WORKS</text>
                <rect x="8" y="12" width="162" height="96" rx="2" fill="rgba(42,107,84,0.55)"/>
                <rect x="8" y="12" width="162" height="22" rx="2" fill="rgba(42,107,84,0.9)"/>
                <text x="89" y="27" font-family="Inter,sans-serif" font-size="7.5" font-weight="700" fill="#D4E84A" text-anchor="middle" letter-spacing="1.2">✓  WORKS</text>
                <text x="20" y="50" font-family="Inter,sans-serif" font-size="7.5" fill="rgba(212,232,74,0.7)">✓</text><text x="30" y="50" font-family="Inter,sans-serif" font-size="7.5" fill="rgba(245,240,232,0.58)">Research &amp; synthesis</text>
                <text x="20" y="65" font-family="Inter,sans-serif" font-size="7.5" fill="rgba(212,232,74,0.7)">✓</text><text x="30" y="65" font-family="Inter,sans-serif" font-size="7.5" fill="rgba(245,240,232,0.58)">Content at scale</text>
                <text x="20" y="80" font-family="Inter,sans-serif" font-size="7.5" fill="rgba(212,232,74,0.7)">✓</text><text x="30" y="80" font-family="Inter,sans-serif" font-size="7.5" fill="rgba(245,240,232,0.58)">Faster iteration</text>
                <text x="20" y="95" font-family="Inter,sans-serif" font-size="7.5" fill="rgba(212,232,74,0.4)">✓</text><text x="30" y="95" font-family="Inter,sans-serif" font-size="7.5" fill="rgba(245,240,232,0.32)">Personalization infra</text>
                <rect x="190" y="12" width="162" height="96" rx="2" fill="rgba(18,32,26,0.65)"/>
                <rect x="190" y="12" width="162" height="22" rx="2" fill="rgba(16,26,22,0.95)"/>
                <text x="271" y="27" font-family="Inter,sans-serif" font-size="7.5" font-weight="700" fill="rgba(245,240,232,0.28)" text-anchor="middle" letter-spacing="1.2">✗  HYPE</text>
                <text x="202" y="50" font-family="Inter,sans-serif" font-size="7.5" fill="rgba(210,70,70,0.65)">✗</text><text x="212" y="50" font-family="Inter,sans-serif" font-size="7.5" fill="rgba(245,240,232,0.3)">Autonomous content</text>
                <text x="202" y="65" font-family="Inter,sans-serif" font-size="7.5" fill="rgba(210,70,70,0.65)">✗</text><text x="212" y="65" font-family="Inter,sans-serif" font-size="7.5" fill="rgba(245,240,232,0.3)">AI replacing strategy</text>
                <text x="202" y="80" font-family="Inter,sans-serif" font-size="7.5" fill="rgba(210,70,70,0.65)">✗</text><text x="212" y="80" font-family="Inter,sans-serif" font-size="7.5" fill="rgba(245,240,232,0.3)">Zero-cost content</text>
                <text x="202" y="95" font-family="Inter,sans-serif" font-size="7.5" fill="rgba(210,70,70,0.55)">✗</text><text x="212" y="95" font-family="Inter,sans-serif" font-size="7.5" fill="rgba(245,240,232,0.25)">Broken process automation</text>
              </svg>
            )}
          </div>
          <span class="blc-tag">{post.data.tag}</span>
          <div class="blc-title">{post.data.title}</div>
          <div class="blc-excerpt">{post.data.excerpt}</div>
          <div class="blc-meta">
            <span class="blc-date">{post.data.date.toLocaleDateString('en-GB',{day:'numeric',month:'long',year:'numeric'})} · {post.data.readTime}</span>
            <span class="blc-arrow">→</span>
          </div>
        </a>
      ))}
    </div>
  </section>
) : (
  <div class="blog-empty">
    <div class="blog-empty-icon">✍️</div>
    <h2 class="blog-empty-h">Articles coming soon.</h2>
    <p class="blog-empty-body">We're writing the first batch of articles now. No filler, no SEO fluff — just the honest thinking we wish we'd read earlier in our careers.</p>
  </div>
)}

</Base>

<style>
.blog-hero{padding:calc(68px + clamp(44px,6vw,72px)) var(--pad) clamp(44px,6vw,64px);background:var(--forest);position:relative;overflow:hidden}
.blog-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 70% 30%,rgba(212,232,74,0.06) 0%,transparent 55%);pointer-events:none}
.blog-hero-inner{max-width:660px;position:relative;z-index:1}
.blog-hero-eyebrow{font-size:9px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:var(--lime);opacity:.6;display:flex;align-items:center;gap:10px;margin-bottom:18px}
.blog-hero-eyebrow::before{content:'';display:block;width:18px;height:1px;background:var(--lime)}
.blog-hero-h1{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(28px,4.5vw,56px);font-weight:800;letter-spacing:-0.04em;line-height:.96;color:var(--cream);margin-bottom:16px}
.blog-hero-sub{font-size:clamp(13px,1.6vw,16px);color:rgba(245,240,232,.45);line-height:1.8;max-width:500px}
.blog-grid-section{padding:clamp(44px,6vw,72px) var(--pad);background:var(--cream)}
.blog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
@media(max-width:900px){.blog-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:560px){.blog-grid{grid-template-columns:1fr}}
.blog-list-card{background:var(--linen);text-decoration:none;padding:clamp(22px,3vw,32px);display:flex;flex-direction:column;gap:10px;transition:background .2s}
.blog-list-card:hover{background:#ddd8ce}
.blog-list-card:first-child{background:var(--forest)}
.blog-list-card:first-child:hover{background:#235e48}
.blc-tag{font-size:9px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--lime)}
.blog-list-card:not(:first-child) .blc-tag{color:var(--mid)}
.blc-title{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(15px,2vw,20px);font-weight:700;line-height:1.2;color:var(--cream);flex:1}
.blog-list-card:not(:first-child) .blc-title{color:var(--forest)}
.blc-excerpt{font-size:12.5px;line-height:1.7;color:rgba(245,240,232,.45)}
.blog-list-card:not(:first-child) .blc-excerpt{color:rgba(28,74,58,.55)}
.blc-meta{display:flex;align-items:center;justify-content:space-between;padding-top:14px;border-top:1px solid rgba(245,240,232,.08);margin-top:auto}
.blog-list-card:not(:first-child) .blc-meta{border-top-color:rgba(28,74,58,.1)}
.blc-date{font-size:10px;color:rgba(245,240,232,.3)}
.blog-list-card:not(:first-child) .blc-date{color:rgba(28,74,58,.35)}
.blc-arrow{font-size:14px;color:var(--lime);transition:transform .2s}
.blog-list-card:not(:first-child) .blc-arrow{color:var(--forest);opacity:.5}
.blog-list-card:hover .blc-arrow{transform:translateX(4px)}
.blc-illo{width:100%;overflow:hidden;flex-shrink:0;aspect-ratio:16/6}
.blog-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:clamp(64px,8vw,96px) var(--pad);text-align:center;background:var(--linen)}
.blog-empty-icon{font-size:48px;margin-bottom:24px;opacity:.4}
.blog-empty-h{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(22px,3vw,32px);font-weight:800;color:var(--forest);margin-bottom:12px}
.blog-empty-body{font-size:14px;color:var(--gray);max-width:400px;line-height:1.7}
</style>
