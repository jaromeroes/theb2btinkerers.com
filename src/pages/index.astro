---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import BlogImage from '../components/BlogImage.astro';
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---
<Base title="The B2B Tinkerers" description="We help B2B tech and industrial companies get more from marketing — without spending more. Not an agency. An insider.">

<!-- HERO -->
<section class="hero">
  <video
    class="hero-video"
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    aria-hidden="true"
  >
    <source src="/hero-bg.mp4" type="video/mp4" />
  </video>
  <div class="hero-overlay" aria-hidden="true"></div>
  <canvas class="hero-grain" id="hero-grain" aria-hidden="true"></canvas>
  <div class="hero-content">
    <div class="hero-eyebrow">B2B Strategic Marketing</div>
    <h1 class="hero-h1">Your marketing budget<br/>isn't the problem.</h1>
    <span class="hero-accent">How you use it is.</span>
    <p class="hero-body">We help B2B tech and industrial companies get more from marketing — without spending more. Not an agency. An insider.</p>
    <div class="hero-ctas">
      <a class="btn-primary" href="#contact">Book a discovery call →</a>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section class="services" id="services">
  <div class="services-header">
    <div class="section-eyebrow">What we do</div>
    <h2 class="section-h2">We help your marketing team punch above its weight.</h2>
    <p class="section-body">Six ways we connect marketing to the business — and make it stick.</p>
  </div>
  <div class="services-grid">
    <a class="service-card" href="/services/marketing-audit">
      <svg class="service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
      <div class="service-title">Marketing Audit</div>
      <div class="service-body">Honest assessment of where you are: positioning, team, budget, and alignment with business goals.</div>
      <span class="service-more">Learn more →</span>
    </a>
    <a class="service-card" href="/services/ai-strategy">
      <svg class="service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 9h6v6H9z"/><path d="M9 1v3M15 1v3M9 20v3M15 20v3M1 9h3M1 15h3M20 9h3M20 15h3"/></svg>
      <div class="service-title">AI & Hybrid Marketing Strategy</div>
      <div class="service-body">The future marketing team is not fully human nor fully automated. We help you define the hybrid model.</div>
      <span class="service-more">Learn more →</span>
    </a>
    <a class="service-card" href="/services/brand-strategy">
      <svg class="service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      <div class="service-title">Brand Strategy & Positioning</div>
      <div class="service-body">Define what you stand for, who you're for, and why someone should choose you. The foundation.</div>
      <span class="service-more">Learn more →</span>
    </a>
    <a class="service-card" href="/services/go-to-market">
      <svg class="service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
      <div class="service-title">Go-To-Market Strategy</div>
      <div class="service-body">A clear GTM motion that connects your positioning to pipeline. Channels, messages, timing.</div>
      <span class="service-more">Learn more →</span>
    </a>
    <a class="service-card" href="/services/marketing-plan">
      <svg class="service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      <div class="service-title">Marketing Plan & Business Alignment</div>
      <div class="service-body">A marketing plan that reflects real business objectives and that your team will actually follow.</div>
      <span class="service-more">Learn more →</span>
    </a>
    <a class="service-card" href="/services/fractional-cmo">
      <svg class="service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>
      <div class="service-title">Fractional CMO</div>
      <div class="service-body">Senior marketing leadership without the full-time cost. We lead your team and maintain direction.</div>
      <span class="service-more">Learn more →</span>
    </a>
  </div>
</section>

<!-- METHOD -->
<section class="method" id="method">
  <div class="method-header">
    <div class="section-eyebrow">How we work</div>
    <h2 class="section-h2">We don't arrive with answers. We arrive with the right questions.</h2>
  </div>
  <div class="method-steps">
    <div class="method-step"><span class="step-num">01</span><div class="step-title">Diagnose</div><div class="step-body">We audit your current state: positioning, brand, marketing activities, team, and business objectives.</div><span class="step-tag">Phase 1</span></div>
    <div class="method-step"><span class="step-num">02</span><div class="step-title">Design</div><div class="step-body">We build the strategy from the ground up. Designed for your team, your budget, your reality.</div><span class="step-tag">Phase 2</span></div>
    <div class="method-step"><span class="step-num">03</span><div class="step-title">Execute</div><div class="step-body">We work alongside your team to bring it to life. Fast and lean — built to last, not to impress.</div><span class="step-tag">Phase 3</span></div>
    <div class="method-step"><span class="step-num">04</span><div class="step-title">Advise</div><div class="step-body">We stay as your strategic partner. A senior voice when you need one — without the full-time cost.</div><span class="step-tag">Ongoing</span></div>
  </div>
</section>

<!-- RESULTS -->
<section class="results">
  <div class="results-left">
    <div class="section-eyebrow">The numbers</div>
    <h2 class="section-h2">This is what misaligned marketing costs.</h2>
    <p class="section-body">Not our numbers. Industry data from Forrester, Marketo, and ZoomInfo.</p>
    <a class="btn-primary" href="#contact" style="margin-top:32px;display:inline-block">Book a discovery call →</a>
  </div>
  <div class="results-nums">
    <div class="result-card r1"><span class="result-num">65%</span><span class="result-label">of B2B professionals say marketing and sales are not aligned</span><span class="result-source">Forrester Q2 2024</span></div>
    <div class="result-card r2"><span class="result-num">$1T</span><span class="result-label">lost annually due to sales & marketing misalignment</span><span class="result-source">G2 / Industry 2024</span></div>
    <div class="result-card r3"><span class="result-num">+27%</span><span class="result-label">faster profit growth in companies with tight alignment</span><span class="result-source">Marketo / ZoomInfo 2024</span></div>
    <div class="result-card r4"><span class="result-num">8%</span><span class="result-label">of B2B companies have genuinely strong alignment</span><span class="result-source">ZoomInfo / Marketo 2024</span></div>
  </div>
</section>

<!-- BLOG TEASER -->
<section class="blog-teaser">
  <div class="blog-teaser-header">
    <div>
      <div class="section-eyebrow">Insights</div>
      <h2 class="section-h2">What we're thinking about.</h2>
    </div>
    <a class="blog-all-link" href="/insights">All articles →</a>
  </div>
  {posts.length > 0 ? (
    <div class="blog-teaser-grid">
      <a class="blog-card-featured" href={`/insights/${posts[0].slug}`}>
        <div class="blog-card-illo">
          {posts[0].data.image && (
            <BlogImage image={posts[0].data.image} alt={posts[0].data.title} loading="lazy" />
          )}
        </div>
        <div class="blog-card-featured-body">
          <span class="bcard-tag">{posts[0].data.tag}</span>
          <div class="bcard-title">{posts[0].data.title}</div>
          <div class="bcard-excerpt">{posts[0].data.excerpt}</div>
          <div class="bcard-meta">
            <span class="bcard-date">{posts[0].data.date.toLocaleDateString('en-GB',{month:'short',year:'numeric'})} · {posts[0].data.readTime}</span>
            <span class="bcard-arrow">→</span>
          </div>
        </div>
      </a>
      {posts.slice(1).map((post, i) => (
        <a class={`blog-card-secondary${i === 1 ? ' blog-card-dark' : ''}`} href={`/insights/${post.slug}`}>
          <div class="blog-card-illo-sm">
            {post.data.image && (
              <BlogImage image={post.data.image} alt={post.data.title} loading="lazy" />
            )}
          </div>
          <div class="blog-card-secondary-body">
            <span class={`bcard-tag${i === 1 ? '' : ' bcard-tag-light'}`}>{post.data.tag}</span>
            <div class={`bcard-title${i === 1 ? '' : ' bcard-title-dark'}`}>{post.data.title}</div>
            <div class={`bcard-meta${i === 1 ? '' : ' bcard-meta-dark'}`}>
              <span class={`bcard-date${i === 1 ? '' : ' bcard-date-dark'}`}>{post.data.date.toLocaleDateString('en-GB',{month:'short',year:'numeric'})} · {post.data.readTime}</span>
              <span class={`bcard-arrow${i === 1 ? '' : ' bcard-arrow-dark'}`}>→</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  ) : (
    <div class="blog-empty-home">Articles coming soon.</div>
  )}
</section>

</Base>

<style>
/* HERO */
.hero{min-height:70vh;padding:calc(68px + clamp(48px,7vw,96px)) var(--pad) clamp(64px,8vw,100px);display:flex;align-items:center;position:relative;overflow:hidden}

/* VIDEO BACKGROUND */
.hero-video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;opacity:0.45;z-index:0;pointer-events:none}

/* Gradient overlay — denser on left for text legibility, opens up on right */
.hero-overlay{position:absolute;inset:0;background:linear-gradient(105deg,rgba(20,46,36,0.95) 0%,rgba(20,46,36,0.80) 40%,rgba(20,46,36,0.45) 100%);z-index:1;pointer-events:none}

.hero-grain{position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:2;opacity:.45}
.hero-content{position:relative;z-index:3;max-width:680px}

@media(max-width:820px){
  .hero{min-height:auto;padding-top:calc(68px + 44px)}
  .hero-video{object-position:70% center}
  .hero-overlay{background:linear-gradient(180deg,rgba(20,46,36,0.92) 0%,rgba(20,46,36,0.85) 100%)}
}

.hero-eyebrow{display:inline-flex;align-items:center;gap:10px;font-size:10px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:var(--lime);opacity:.9;margin-bottom:24px}
.hero-eyebrow::before{content:'';display:block;width:20px;height:1px;background:var(--lime)}
.hero-h1{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(34px,5.5vw,70px);font-weight:800;letter-spacing:-0.04em;line-height:.95;color:var(--cream);margin-bottom:6px}
.hero-accent{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(34px,5.5vw,70px);font-weight:800;letter-spacing:-0.04em;line-height:.95;color:var(--lime);display:block;margin-bottom:28px}
.hero-body{font-size:clamp(14px,1.8vw,17px);line-height:1.8;color:rgba(245,240,232,0.72);max-width:420px;margin-bottom:36px}
.hero-ctas{display:flex;gap:14px;flex-wrap:wrap;align-items:center}

/* SERVICES */
.services{background:var(--cream);padding:clamp(72px,9vw,112px) var(--pad)}
.services-header{margin-bottom:clamp(36px,5vw,56px);max-width:580px}
.services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
@media(max-width:900px){.services-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:520px){.services-grid{grid-template-columns:1fr}}
.service-card{background:var(--linen);padding:clamp(24px,3vw,36px) clamp(20px,2.5vw,32px);position:relative;transition:background .2s;cursor:pointer;text-decoration:none;display:block}
.service-card:hover{background:var(--forest)}
.service-card:hover .service-icon{color:var(--lime)}
.service-card:hover .service-title{color:var(--cream)}
.service-card:hover .service-body{color:rgba(245,240,232,.7)}
.service-icon{width:28px;height:28px;color:var(--forest);opacity:.5;display:block;margin-bottom:12px;transition:color .2s,opacity .2s}
.service-title{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(13px,1.8vw,16px);font-weight:700;color:var(--forest);margin-bottom:10px;line-height:1.3;transition:color .2s}
.service-body{font-size:12.5px;line-height:1.7;color:rgba(26,26,26,.6);transition:color .2s;padding-bottom:28px}
.service-more{font-size:11px;font-weight:700;letter-spacing:.04em;color:var(--mid);opacity:.7;position:absolute;bottom:20px;left:clamp(20px,2.5vw,32px);transition:color .2s,opacity .2s}
.service-card:hover .service-more{color:var(--lime);opacity:1}

/* METHOD */
.method{padding:clamp(72px,9vw,112px) var(--pad);background:var(--linen)}
.method-header{margin-bottom:clamp(36px,5vw,56px);max-width:520px}
.method-steps{display:grid;grid-template-columns:repeat(4,1fr);gap:2px}
@media(max-width:900px){.method-steps{grid-template-columns:repeat(2,1fr)}}
@media(max-width:480px){.method-steps{grid-template-columns:1fr}}
.method-step{background:var(--cream);padding:clamp(22px,3vw,34px) clamp(18px,2.5vw,28px);transition:background .2s}
.method-step:hover{background:var(--forest)}
.step-num{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:46px;font-weight:800;color:var(--forest);opacity:.25;display:block;line-height:1;margin-bottom:4px;transition:color .2s,opacity .2s}
.method-step:hover .step-num{color:var(--cream);opacity:.09}
.step-title{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(15px,2vw,18px);font-weight:700;color:var(--forest);margin-bottom:10px;transition:color .2s}
.method-step:hover .step-title{color:var(--cream)}
.step-body{font-size:12.5px;line-height:1.7;color:rgba(26,26,26,.82);transition:color .2s}
.method-step:hover .step-body{color:rgba(245,240,232,.58)}
.step-tag{display:inline-block;margin-top:16px;background:var(--lime);color:var(--forest);font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:4px 10px}

/* RESULTS */
.results{padding:clamp(72px,9vw,112px) var(--pad);background:var(--forest);display:grid;grid-template-columns:1fr 1fr;gap:clamp(36px,6vw,88px);align-items:center}
@media(max-width:768px){.results{grid-template-columns:1fr}}
.results-left .section-eyebrow{color:var(--cream);opacity:.7}
.results-left .section-h2{color:var(--cream)}
.results-left .section-body{color:rgba(245,240,232,.72);margin-top:14px}
.results-nums{display:grid;grid-template-columns:1fr 1fr;gap:2px}
.result-card{padding:clamp(20px,3vw,32px) clamp(16px,2.5vw,28px)}
.result-card.r1,.result-card.r4{background:var(--lime)}
.result-card.r2,.result-card.r3{background:var(--mid)}
.result-num{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(32px,4vw,50px);font-weight:800;line-height:1;display:block;margin-bottom:8px}
.r1 .result-num,.r4 .result-num{color:var(--forest)}
.r2 .result-num,.r3 .result-num{color:var(--lime)}
.result-label{font-size:11.5px;line-height:1.55}
.r1 .result-label,.r4 .result-label{color:var(--forest)}
.r2 .result-label,.r3 .result-label{color:rgba(245,240,232,.92)}
.result-source{display:block;margin-top:10px;font-size:9px;font-weight:700;letter-spacing:.08em;text-transform:uppercase}
.r1 .result-source,.r4 .result-source{color:rgba(28,74,58,.7)}
.r2 .result-source,.r3 .result-source{color:rgba(245,240,232,.65)}

/* BLOG TEASER */
.blog-teaser{padding:clamp(72px,9vw,112px) var(--pad);background:var(--cream)}
.blog-teaser-header{display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:clamp(32px,5vw,52px)}
.blog-teaser-header .section-h2{margin-bottom:0}
.blog-all-link{font-size:12px;font-weight:600;color:var(--forest);border-bottom:1px solid rgba(28,74,58,0.3);padding-bottom:2px;text-decoration:none;transition:border-color .15s}
.blog-all-link:hover{border-color:var(--forest)}
.blog-teaser-grid{display:grid;grid-template-columns:1fr 1fr;grid-template-rows:auto auto;gap:2px}
@media(max-width:700px){.blog-teaser-grid{grid-template-columns:1fr}}
.blog-card-featured{grid-column:1;grid-row:1/3;background:var(--forest);text-decoration:none;display:flex;flex-direction:column;transition:opacity .2s}
.blog-card-featured:hover{opacity:.92}
.blog-card-illo{width:100%;aspect-ratio:16/7;overflow:hidden;flex-shrink:0;max-height:220px}
.blog-card-featured-body{padding:clamp(22px,3vw,32px);flex:1;display:flex;flex-direction:column}
.bcard-tag{font-size:9px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--lime);margin-bottom:12px;display:block}
.bcard-title{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(16px,2.2vw,22px);font-weight:700;line-height:1.2;color:var(--cream);margin-bottom:12px}
.bcard-excerpt{font-size:13px;line-height:1.7;color:rgba(245,240,232,.78);margin-bottom:20px;flex:1}
.bcard-meta{display:flex;align-items:center;justify-content:space-between;padding-top:16px;border-top:1px solid rgba(245,240,232,.08)}
.bcard-date{font-size:10px;color:rgba(245,240,232,.72)}
.bcard-arrow{font-size:16px;color:var(--lime);transition:transform .2s}
.blog-card-featured:hover .bcard-arrow{transform:translateX(4px)}
.blog-card-secondary{background:var(--linen);text-decoration:none;display:flex;flex-direction:column;transition:background .2s}
.blog-card-secondary:hover{background:#ddd8ce}
.blog-card-secondary:last-child{background:var(--forest)}
.blog-card-secondary:last-child:hover{background:#235e48}
.blog-card-dark .bcard-tag-light{color:var(--lime)}
.blog-card-dark .bcard-title-dark{color:var(--cream)}
.blog-card-dark .bcard-meta-dark{border-top-color:rgba(245,240,232,.1)}
.blog-card-dark .bcard-date-dark{color:rgba(245,240,232,.72)}
.blog-card-dark .bcard-arrow-dark{color:var(--lime);opacity:.7}
.blog-card-illo-sm{width:100%;aspect-ratio:16/6;overflow:hidden;flex-shrink:0}
.blog-card-secondary-body{padding:clamp(18px,2.5vw,26px);flex:1;display:flex;flex-direction:column}
.bcard-tag-light{font-size:9px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--mid);margin-bottom:10px;display:block}
.bcard-title-dark{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(14px,1.8vw,17px);font-weight:700;line-height:1.25;color:var(--forest);margin-bottom:auto;padding-bottom:16px;flex:1}
.bcard-meta-dark{display:flex;align-items:center;justify-content:space-between;padding-top:14px;border-top:1px solid rgba(28,74,58,.1)}
.bcard-date-dark{font-size:10px;color:rgba(28,74,58,.72)}
.bcard-arrow-dark{font-size:14px;color:var(--forest);opacity:.4;transition:transform .2s}
.blog-card-secondary:hover .bcard-arrow-dark{transform:translateX(4px)}
.blog-empty-home{padding:48px;text-align:center;font-size:14px;color:var(--gray);background:var(--linen)}
</style>

<script>
// Grain effect — deferred after LCP to avoid render blocking
function initGrain(){
  const canvas = document.getElementById('hero-grain');
  if(!canvas) return;
  const hero = canvas.closest('.hero');
  let w = 0, h = 0;
  function resize(){
    w = hero.offsetWidth;
    h = hero.offsetHeight;
    canvas.width = w;
    canvas.height = h;
    render();
  }
  function render(){
    const ctx=canvas.getContext('2d');
    const imageData=ctx.createImageData(w,h);
    const data=imageData.data;
    for(let i=0;i<data.length;i+=4){const v=(Math.random()*255)|0;data[i]=data[i+1]=data[i+2]=v;data[i+3]=14;}
    ctx.putImageData(imageData,0,0);
  }
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(resize, 150);
  }, {passive:true});
  resize();
}

if(document.readyState === 'complete') {
  setTimeout(initGrain, 100);
} else {
  window.addEventListener('load', () => setTimeout(initGrain, 100), {once:true});
}
</script>
