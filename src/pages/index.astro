---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Base title="The B2B Tinkerers" description="We help B2B tech and industrial companies get more from marketing — without spending more. Not an agency. An insider.">

<!-- HERO -->
<section class="hero">
  <div class="hero-content">
    <div class="hero-eyebrow">B2B Strategic Marketing</div>
    <h1 class="hero-h1">Stop wasting budget<br>on marketing that doesn't work.</h1>
    <span class="hero-accent">Start building what does.</span>
    <p class="hero-body">We help B2B tech and industrial companies get more from marketing — without spending more. Not an agency. An insider.</p>
    <div class="hero-ctas">
      <a class="btn-primary" href="#contact">Book a discovery call →</a>
      <a class="btn-ghost" href="#services">See how we work</a>
    </div>
  </div>
  <div class="hero-illo">
    <svg viewBox="0 0 480 500" fill="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="gCream" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#F5F0E8"/><stop offset="100%" stop-color="#E8E3D8"/></linearGradient>
        <linearGradient id="gLime" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#D4E84A"/><stop offset="100%" stop-color="#B8D030"/></linearGradient>
        <linearGradient id="gForest" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#2A6B54"/><stop offset="100%" stop-color="#1C4A3A"/></linearGradient>
        <filter id="shadow"><feDropShadow dx="0" dy="8" stdDeviation="12" flood-color="#0A1F18" flood-opacity="0.35"/></filter>
      </defs>
      <circle cx="240" cy="250" r="190" fill="rgba(42,107,84,0.15)"/>
      <circle cx="240" cy="250" r="130" fill="rgba(42,107,84,0.1)"/>
      <circle cx="240" cy="248" r="56" stroke="rgba(212,232,74,0.2)" stroke-width="1.5" fill="none"/>
      <line x1="120" y1="120" x2="200" y2="210" stroke="rgba(212,232,74,0.35)" stroke-width="1.5" stroke-dasharray="6 4" class="illo-line"/>
      <line x1="360" y1="120" x2="280" y2="210" stroke="rgba(212,232,74,0.35)" stroke-width="1.5" stroke-dasharray="6 4" class="illo-line" style="animation-delay:.4s"/>
      <line x1="100" y1="360" x2="196" y2="280" stroke="rgba(212,232,74,0.35)" stroke-width="1.5" stroke-dasharray="6 4" class="illo-line" style="animation-delay:.8s"/>
      <line x1="380" y1="360" x2="284" y2="280" stroke="rgba(212,232,74,0.35)" stroke-width="1.5" stroke-dasharray="6 4" class="illo-line" style="animation-delay:1.2s"/>
      <g class="illo-card-a" filter="url(#shadow)">
        <rect x="34" y="60" width="152" height="90" rx="6" fill="url(#gCream)"/>
        <rect x="34" y="60" width="4" height="90" rx="2" fill="url(#gForest)"/>
        <text x="50" y="81" font-family="Inter,sans-serif" font-size="7.5" font-weight="700" letter-spacing="1.5" fill="#1C4A3A" opacity="0.45">BUSINESS GOALS</text>
        <rect x="98" y="78" width="10" height="46" rx="1.5" fill="url(#gLime)"/>
        <circle cx="144" cy="96" r="2.5" fill="#D4E84A"/>
      </g>
      <g class="illo-card-b" filter="url(#shadow)">
        <rect x="292" y="60" width="152" height="90" rx="6" fill="url(#gForest)"/>
        <text x="308" y="81" font-family="Inter,sans-serif" font-size="7.5" font-weight="700" letter-spacing="1.5" fill="#D4E84A" opacity="0.6">MARKETING</text>
        <text x="394" y="128" font-family="Inter,sans-serif" font-size="10" font-weight="700" fill="#D4E84A">94%</text>
      </g>
      <g filter="url(#shadow)">
        <circle cx="240" cy="248" r="52" fill="url(#gLime)"/>
        <circle cx="240" cy="248" r="44" fill="url(#gForest)"/>
        <rect x="220" y="228" width="40" height="9" rx="2" fill="#D4E84A"/>
        <rect x="235.5" y="237" width="9" height="26" rx="2" fill="#D4E84A"/>
      </g>
      <g class="illo-card-b" filter="url(#shadow)" style="animation-delay:.3s">
        <rect x="28" y="330" width="148" height="88" rx="6" fill="url(#gForest)"/>
        <rect x="28" y="330" width="148" height="4" rx="2" fill="url(#gLime)"/>
        <text x="44" y="376" font-family="Inter,sans-serif" font-size="22" font-weight="800" fill="#F5F0E8" letter-spacing="-1">+27%</text>
      </g>
      <g class="illo-card-a" filter="url(#shadow)" style="animation-delay:.6s">
        <rect x="298" y="330" width="150" height="88" rx="6" fill="url(#gCream)"/>
        <rect x="298" y="330" width="150" height="4" rx="2" fill="url(#gForest)"/>
        <rect x="314" y="403" width="80" height="14" rx="3" fill="#1C4A3A"/>
        <text x="321" y="413" font-family="Inter,sans-serif" font-size="7" font-weight="700" fill="#D4E84A" letter-spacing="1">ALIGNED</text>
      </g>
    </svg>
  </div>
</section>

<!-- MARQUEE -->
<div class="marquee-wrap">
  <div class="marquee-track">
    <span class="marquee-item">Marketing-Business Alignment</span><span class="marquee-sep">✦</span>
    <span class="marquee-item">Go-To-Market Strategy</span><span class="marquee-sep">✦</span>
    <span class="marquee-item">Fractional CMO</span><span class="marquee-sep">✦</span>
    <span class="marquee-item">AI-Augmented Marketing</span><span class="marquee-sep">✦</span>
    <span class="marquee-item">Demand Generation</span><span class="marquee-sep">✦</span>
    <span class="marquee-item">Brand Strategy</span><span class="marquee-sep">✦</span>
    <span class="marquee-item">Revenue Architecture</span><span class="marquee-sep">✦</span>
    <span class="marquee-item">Marketing-Business Alignment</span><span class="marquee-sep">✦</span>
    <span class="marquee-item">Go-To-Market Strategy</span><span class="marquee-sep">✦</span>
    <span class="marquee-item">Fractional CMO</span><span class="marquee-sep">✦</span>
    <span class="marquee-item">AI-Augmented Marketing</span><span class="marquee-sep">✦</span>
    <span class="marquee-item">Demand Generation</span><span class="marquee-sep">✦</span>
    <span class="marquee-item">Brand Strategy</span><span class="marquee-sep">✦</span>
    <span class="marquee-item">Revenue Architecture</span><span class="marquee-sep">✦</span>
  </div>
</div>

<!-- SERVICES -->
<section class="services" id="services">
  <div class="services-header">
    <div class="section-eyebrow">What we do</div>
    <h2 class="section-h2">We help your marketing team punch above its weight.</h2>
    <p class="section-body">Six ways we connect marketing to the business — and make it stick.</p>
  </div>
  <div class="services-grid">
    <div class="service-card"><span class="service-num">01</span><div class="service-title">Marketing Audit</div><div class="service-body">Honest assessment of where you are: positioning, team, budget, and alignment with business goals.</div><span class="service-arrow">→</span></div>
    <div class="service-card featured"><span class="service-num">02</span><div class="service-title">Brand Strategy & Positioning</div><div class="service-body">Define what you stand for, who you're for, and why someone should choose you. The foundation.</div><span class="service-arrow">→</span></div>
    <div class="service-card"><span class="service-num">03</span><div class="service-title">Go-To-Market Strategy</div><div class="service-body">A clear GTM motion that connects your positioning to pipeline. Channels, messages, timing — aligned.</div><span class="service-arrow">→</span></div>
    <div class="service-card"><span class="service-num">04</span><div class="service-title">Marketing Plan & Business Alignment</div><div class="service-body">A marketing plan that reflects real business objectives — and that your team will actually follow.</div><span class="service-arrow">→</span></div>
    <div class="service-card"><span class="service-num">05</span><div class="service-title">AI & Hybrid Marketing Strategy</div><div class="service-body">The future marketing team is not fully human — nor fully automated. We help you define the hybrid model.</div><span class="service-arrow">→</span></div>
    <div class="service-card"><span class="service-num">06</span><div class="service-title">Fractional CMO</div><div class="service-body">Senior marketing leadership without the full-time cost. We lead your team and maintain direction.</div><span class="service-arrow">→</span></div>
  </div>
</section>

<!-- METHOD -->
<section class="method" id="method">
  <div class="method-header">
    <div class="section-eyebrow">How we work</div>
    <h2 class="section-h2">We don't arrive with answers. We arrive with the right questions.</h2>
  </div>
  <div class="method-steps">
    <div class="method-step"><span class="step-num">01</span><div class="step-title">Diagnose</div><div class="step-body">We audit your current state: positioning, brand, marketing activities, team, and business objectives.</div><span class="step-tag">Week 1–2</span></div>
    <div class="method-step"><span class="step-num">02</span><div class="step-title">Design</div><div class="step-body">We build the strategy from the ground up. Designed for your team, your budget, your reality.</div><span class="step-tag">Week 3–5</span></div>
    <div class="method-step"><span class="step-num">03</span><div class="step-title">Execute</div><div class="step-body">We work alongside your team to bring it to life. Fast and lean — built to last, not to impress.</div><span class="step-tag">Week 6–10</span></div>
    <div class="method-step dark"><span class="step-num">04</span><div class="step-title">Advise</div><div class="step-body">We stay as your strategic partner. A senior voice when you need one — without the full-time cost.</div><span class="step-tag">Ongoing</span></div>
  </div>
</section>

<!-- RESULTS -->
<section class="results">
  <div class="results-left">
    <div class="section-eyebrow">The numbers</div>
    <h2 class="section-h2">This is what misaligned marketing costs.</h2>
    <p class="section-body">Not our numbers. Industry data from Forrester, Marketo, and ZoomInfo.</p>
    <a class="btn-primary" href="#contact" style="margin-top:28px;display:inline-block">Book a discovery call →</a>
  </div>
  <div class="results-nums">
    <div class="result-card r1"><span class="result-num">65%</span><span class="result-label">of B2B professionals say marketing and sales are not aligned</span><span class="result-source">Forrester Q2 2024</span></div>
    <div class="result-card r2"><span class="result-num">$1T</span><span class="result-label">lost annually due to sales & marketing misalignment</span><span class="result-source">G2 / Industry 2024</span></div>
    <div class="result-card r3"><span class="result-num">+27%</span><span class="result-label">faster profit growth in companies with tight alignment</span><span class="result-source">Marketo / ZoomInfo 2024</span></div>
    <div class="result-card r4"><span class="result-num">8%</span><span class="result-label">of B2B companies have genuinely strong alignment</span><span class="result-source">ZoomInfo / Marketo 2024</span></div>
  </div>
</section>

<!-- BLOG TEASER -->
<section class="blog-teaser">
  <div class="blog-teaser-header">
    <div>
      <div class="section-eyebrow">Insights</div>
      <h2 class="section-h2">What we're thinking about.</h2>
    </div>
    <a class="blog-all-link" href="/insights">All articles →</a>
  </div>
  <div class="blog-teaser-grid">
    {posts.map((post) => (
      <a class="blog-card" href={`/insights/${post.slug}`}>
        <div class="blog-card-body">
          <span class="blog-card-tag">{post.data.tag}</span>
          <div class="blog-card-title">{post.data.title}</div>
          <div class="blog-card-excerpt">{post.data.excerpt}</div>
          <div class="blog-card-meta">
            <span class="blog-card-date">{post.data.date.toLocaleDateString('en-GB', {month:'short', year:'numeric'})} · {post.data.readTime ?? '5 min read'}</span>
            <span class="blog-card-arrow">→</span>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>

<!-- CTA -->
<section class="cta-section" id="contact">
  <div>
    <div class="section-eyebrow">Work with us</div>
    <h2 class="cta-h2">Your team is ready.<br>What's missing<br>is the direction.</h2>
    <p class="cta-sub">Senior marketing leadership — without the full-time cost. Let's start with an honest conversation.</p>
  </div>
  <div class="cta-right">
    <a class="btn-dark" href="mailto:hello@theb2btinkerers.com">Book a discovery call →</a>
    <span class="cta-micro">30 minutes. No pitch. Just an honest conversation.</span>
  </div>
</section>

</Base>

<style>
.hero{min-height:100vh;background:var(--forest);padding:calc(56px + clamp(48px,7vw,96px)) var(--pad) clamp(60px,8vw,100px);display:grid;grid-template-columns:1fr 1fr;gap:clamp(24px,5vw,64px);align-items:center;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 75% 20%,rgba(212,232,74,0.07) 0%,transparent 55%);pointer-events:none}
@media(max-width:820px){.hero{grid-template-columns:1fr;min-height:auto;padding-top:calc(56px + 44px);gap:40px}}
.hero-eyebrow{display:inline-flex;align-items:center;gap:8px;font-size:10px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:var(--lime);margin-bottom:22px;opacity:.75}
.hero-eyebrow::before{content:'';display:block;width:18px;height:1px;background:var(--lime)}
.hero-h1{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(32px,5vw,66px);font-weight:800;letter-spacing:-0.04em;line-height:.96;color:var(--cream);margin-bottom:4px}
.hero-accent{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(32px,5vw,66px);font-weight:800;letter-spacing:-0.04em;line-height:.96;color:var(--lime);display:block;margin-bottom:24px}
.hero-body{font-size:clamp(14px,1.7vw,16px);line-height:1.75;color:rgba(245,240,232,0.5);max-width:400px;margin-bottom:32px}
.hero-ctas{display:flex;gap:12px;flex-wrap:wrap;align-items:center}
.btn-primary{background:var(--lime);color:var(--forest);font-family:'Inter',sans-serif;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:13px 26px;transition:opacity .15s;text-decoration:none;display:inline-block}
.btn-primary:hover{opacity:.88}
.btn-ghost{background:transparent;color:rgba(245,240,232,0.45);font-family:'Inter',sans-serif;font-size:12px;font-weight:500;padding:13px 4px;border-bottom:1px solid rgba(245,240,232,.18);text-decoration:none}
.hero-illo{display:flex;align-items:center;justify-content:center}
.hero-illo svg{width:100%;max-width:480px;height:auto}
@keyframes floatA{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
@keyframes floatB{0%,100%{transform:translateY(0)}50%{transform:translateY(6px)}}
@keyframes dash{to{stroke-dashoffset:-40}}
.illo-card-a{animation:floatA 5s ease-in-out infinite}
.illo-card-b{animation:floatB 6s ease-in-out infinite .5s}
.illo-line{animation:dash 2s linear infinite;stroke-dasharray:6 4}
.marquee-wrap{background:var(--lime);padding:11px 0;overflow:hidden}
.marquee-track{display:inline-flex;white-space:nowrap;animation:marquee 32s linear infinite}
@keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.marquee-item{font-family:'Bricolage Grotesque',sans-serif;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--forest);padding:0 24px}
.marquee-sep{color:var(--forest);opacity:.3;font-size:9px}
.section-eyebrow{font-size:9px;font-weight:700;letter-spacing:0.25em;text-transform:uppercase;color:var(--forest);opacity:.4;display:flex;align-items:center;gap:10px;margin-bottom:16px}
.section-eyebrow::before{content:'';display:block;width:14px;height:1px;background:currentColor}
.section-h2{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(24px,3.2vw,42px);font-weight:800;letter-spacing:-0.04em;line-height:1.02;color:var(--forest);margin-bottom:16px}
.section-body{font-size:clamp(13px,1.5vw,15px);line-height:1.8;color:var(--gray)}
.services{background:var(--forest);padding:clamp(64px,9vw,108px) var(--pad)}
.services-header{margin-bottom:clamp(32px,5vw,52px);max-width:560px}
.services-header .section-eyebrow{color:var(--cream);opacity:.22}
.services-header .section-h2{color:var(--cream)}
.services-header .section-body{color:rgba(245,240,232,.4)}
.services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
@media(max-width:900px){.services-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:520px){.services-grid{grid-template-columns:1fr}}
.service-card{background:var(--mid);padding:clamp(22px,3vw,34px) clamp(18px,2.5vw,30px);position:relative;transition:background .18s}
.service-card:hover{background:#235e48}
.service-card.featured{background:var(--lime)}
.service-num{font-family:'Bricolage Grotesque',sans-serif;font-size:38px;font-weight:800;color:var(--forest);opacity:.1;display:block;line-height:1;margin-bottom:4px}
.service-card.featured .service-num{opacity:.15}
.service-title{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(13px,1.8vw,16px);font-weight:700;color:var(--cream);margin-bottom:8px;line-height:1.3}
.service-card.featured .service-title{color:var(--forest)}
.service-body{font-size:12px;line-height:1.65;color:rgba(245,240,232,.43)}
.service-card.featured .service-body{color:rgba(28,74,58,.6)}
.service-arrow{position:absolute;bottom:18px;right:18px;font-size:14px;color:var(--lime);opacity:.35}
.method{padding:clamp(64px,9vw,108px) var(--pad);background:var(--linen)}
.method-header{margin-bottom:clamp(32px,5vw,52px);max-width:500px}
.method-steps{display:grid;grid-template-columns:repeat(4,1fr);gap:2px}
@media(max-width:900px){.method-steps{grid-template-columns:repeat(2,1fr)}}
@media(max-width:480px){.method-steps{grid-template-columns:1fr}}
.method-step{background:var(--cream);padding:clamp(20px,3vw,32px) clamp(16px,2.5vw,26px)}
.method-step.dark{background:var(--forest)}
.step-num{font-family:'Bricolage Grotesque',sans-serif;font-size:44px;font-weight:800;color:var(--forest);opacity:.07;display:block;line-height:1;margin-bottom:2px}
.method-step.dark .step-num{color:var(--cream)}
.step-title{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(14px,1.9vw,17px);font-weight:700;color:var(--forest);margin-bottom:8px}
.method-step.dark .step-title{color:var(--cream)}
.step-body{font-size:12px;line-height:1.65;color:var(--gray)}
.method-step.dark .step-body{color:rgba(245,240,232,.45)}
.step-tag{display:inline-block;margin-top:14px;background:var(--lime);color:var(--forest);font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:3px 9px}
.results{padding:clamp(64px,9vw,108px) var(--pad);background:var(--forest);display:grid;grid-template-columns:1fr 1fr;gap:clamp(32px,6vw,80px);align-items:center}
@media(max-width:768px){.results{grid-template-columns:1fr}}
.results-left .section-eyebrow{color:var(--cream);opacity:.22}
.results-left .section-h2{color:var(--cream)}
.results-left .section-body{color:rgba(245,240,232,.4);margin-top:12px}
.results-nums{display:grid;grid-template-columns:1fr 1fr;gap:2px}
.result-card{padding:clamp(18px,3vw,30px) clamp(14px,2.5vw,26px)}
.result-card.r1,.result-card.r4{background:var(--lime)}
.result-card.r2,.result-card.r3{background:var(--mid)}
.result-num{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(32px,4vw,46px);font-weight:800;line-height:1;display:block;margin-bottom:6px}
.r1 .result-num,.r4 .result-num{color:var(--forest)}
.r2 .result-num,.r3 .result-num{color:var(--lime)}
.result-label{font-size:11px;line-height:1.55}
.r1 .result-label,.r4 .result-label{color:rgba(28,74,58,.6)}
.r2 .result-label,.r3 .result-label{color:rgba(245,240,232,.45)}
.result-source{display:block;margin-top:8px;font-size:9px;font-weight:700;letter-spacing:.08em;text-transform:uppercase}
.r1 .result-source,.r4 .result-source{color:rgba(28,74,58,.3)}
.r2 .result-source,.r3 .result-source{color:rgba(245,240,232,.2)}
.blog-teaser{padding:clamp(64px,9vw,108px) var(--pad);background:var(--cream)}
.blog-teaser-header{display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:clamp(32px,5vw,48px)}
.blog-teaser-header .section-h2{margin-bottom:0}
.blog-all-link{font-size:12px;font-weight:600;color:var(--forest);border-bottom:1px solid rgba(28,74,58,0.25);padding-bottom:2px;text-decoration:none;white-space:nowrap}
.blog-teaser-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:2px}
@media(max-width:900px){.blog-teaser-grid{grid-template-columns:1fr 1fr}}
@media(max-width:560px){.blog-teaser-grid{grid-template-columns:1fr}}
.blog-card{background:var(--linen);text-decoration:none;display:flex;flex-direction:column;transition:background .18s}
.blog-card:hover{background:#ddd8ce}
.blog-card:first-child{background:var(--forest)}
.blog-card-body{padding:clamp(18px,2.5vw,24px);flex:1;display:flex;flex-direction:column}
.blog-card-tag{font-size:9px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:var(--lime);margin-bottom:10px;display:block}
.blog-card:not(:first-child) .blog-card-tag{color:var(--mid)}
.blog-card-title{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(14px,2vw,17px);font-weight:700;line-height:1.25;color:var(--cream);margin-bottom:10px}
.blog-card:not(:first-child) .blog-card-title{color:var(--forest)}
.blog-card-excerpt{font-size:12px;line-height:1.65;color:rgba(245,240,232,.45);flex:1}
.blog-card:not(:first-child) .blog-card-excerpt{color:rgba(28,74,58,.55)}
.blog-card-meta{display:flex;align-items:center;justify-content:space-between;margin-top:16px;padding-top:12px;border-top:1px solid rgba(245,240,232,.08)}
