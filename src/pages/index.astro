---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---
<Base title="The B2B Tinkerers" description="We help B2B tech, industrial, and financial services companies get more from marketing — without spending more. Not an agency. An insider.">

<!-- HERO -->
<section class="hero">
  <div class="hero-glow" aria-hidden="true"></div>
  <div class="hero-grain" aria-hidden="true"></div>
  <div class="hero-content">
    <p class="hero-kick">The anti-agency.</p>
    <h1 class="hero-h1">Your marketing budget isn't the problem. <span class="hero-accent">How you use it is.</span></h1>
    <p class="hero-body">We help B2B tech, industrial, and financial services companies get more from marketing, without spending more. Not an agency. An insider.</p>
    <div class="hero-ctas">
      <a class="btn-primary" href="#contact">Book a discovery call →</a>
      <a class="hero-link" href="#work">See how we think →</a>
    </div>
  </div>
</section>

<!-- BELIEF -->
<section class="sec belief">
  <div class="sec-in">
    <div class="section-eyebrow">What we believe</div>
    <h2 class="belief-h">We don't arrive with answers. We arrive with the <span class="u-ch">right questions.</span></h2>
    <p class="belief-p">Most agencies sell you activity: decks, retainers, a busy calendar. We sell you clarity about where your budget should actually go, and the plan to get it there. Less theatre, more thinking.</p>
  </div>
</section>

<!-- THE WORK — three questions -->
<section class="sec sec--line work" id="work">
  <div class="sec-in">
    <div class="section-eyebrow">The work</div>
    <h2 class="section-h2">Three questions we answer better than anyone.</h2>
    <div class="work-grid">
      <a class="work-card" href="/services/marketing-audit">
        <span class="work-q">Q1</span>
        <div class="work-title">Strategy</div>
        <div class="work-body">Where the budget actually should go, and what to stop funding. The unglamorous audit that pays for itself before we finish it.</div>
        <span class="work-more">Learn more →</span>
      </a>
      <a class="work-card" href="/services/brand-strategy">
        <span class="work-q">Q2</span>
        <div class="work-title">Positioning</div>
        <div class="work-body">Why you, and why now, in words your buyers actually repeat. Not a tagline. A point of view that makes the sale easier.</div>
        <span class="work-more">Learn more →</span>
      </a>
      <a class="work-card" href="/services/go-to-market">
        <span class="work-q">Q3</span>
        <div class="work-title">Go-to-market</div>
        <div class="work-body">The plan that survives contact with the pipeline. Channels, motion and metrics your team can run without us in the room.</div>
        <span class="work-more">Learn more →</span>
      </a>
    </div>
    <p class="work-foot">Six ways we help, told as three. <a href="/services">See every service →</a></p>
  </div>
</section>

<!-- PROOF — anti-agency numbers -->
<section class="sec sec--line proof">
  <div class="sec-in">
    <div class="section-eyebrow">How we're different</div>
    <h2 class="section-h2">The anti-agency, in three numbers.</h2>
    <div class="proof-grid">
      <div class="proof-item">
        <div class="proof-n"><u>30</u> min</div>
        <p class="proof-t">The first call. No pitch, no slides. An honest read on whether we can help.</p>
      </div>
      <div class="proof-item">
        <div class="proof-n">0</div>
        <p class="proof-t">Retainers that buy you decks instead of decisions. We scope to the problem, not the calendar.</p>
      </div>
      <div class="proof-item">
        <div class="proof-n">1</div>
        <p class="proof-t">Senior operator on your account. The person you meet is the person who does the work.</p>
      </div>
    </div>
  </div>
</section>

<!-- THE WAY WE WORK -->
<section class="sec sec--line howwork">
  <div class="sec-in howwork-grid">
    <div>
      <div class="section-eyebrow">The way we work</div>
      <h2 class="section-h2">Honest even when it's uncomfortable.</h2>
      <p class="howwork-lead">If your problem isn't marketing, we'll tell you. If a cheaper path exists, we'll point at it. Trust compounds faster than billings.</p>
    </div>
    <div class="howwork-list">
      <div class="howwork-item">
        <span class="hw-k">01</span>
        <div><h4>We start with the business, not the channel</h4><p>Pipeline math before campaign ideas. Everything ladders up to revenue or it doesn't get funded.</p></div>
      </div>
      <div class="howwork-item">
        <span class="hw-k">02</span>
        <div><h4>We hand you capability, not dependency</h4><p>The goal is a team that outgrows us. We build the muscle, then get out of the way.</p></div>
      </div>
      <div class="howwork-item">
        <span class="hw-k">03</span>
        <div><h4>We say no to the wrong-fit work</h4><p>Focus is the product. If we're not the right people, we'll name who is.</p></div>
      </div>
    </div>
  </div>
</section>

<!-- INSIGHTS -->
<section class="sec sec--line insights">
  <div class="sec-in">
    <div class="ins-head">
      <div>
        <div class="section-eyebrow">Insights</div>
        <h2 class="section-h2">Thinking, in the open.</h2>
      </div>
      <a class="ins-all" href="/insights">All insights →</a>
    </div>
    {posts.length > 0 ? (
      <div class="ins-grid">
        {posts.map(post => (
          <a class="ins-card" href={`/insights/${post.slug}`}>
            <span class="ins-tag">{post.data.tag}</span>
            <span class="ins-title">{post.data.title}</span>
            <span class="ins-meta">{post.data.date.toLocaleDateString('en-GB',{month:'short',year:'numeric'})}{post.data.readTime ? ` · ${post.data.readTime}` : ''}</span>
          </a>
        ))}
      </div>
    ) : (
      <div class="ins-empty">Articles coming soon.</div>
    )}
  </div>
</section>

</Base>

<style>
/* ===== HERO — cool gradient ===== */
.hero{min-height:78vh;padding:calc(68px + clamp(56px,9vw,116px)) var(--pad) clamp(72px,11vw,132px);display:flex;align-items:center;position:relative;overflow:hidden;color:var(--cream);
  background:#07231A;
  background-image:
    radial-gradient(95% 85% at 80% 8%,rgba(183,214,43,.30),transparent 52%),
    radial-gradient(70% 70% at 12% 96%,rgba(53,224,200,.16),transparent 60%),
    linear-gradient(158deg,#07231A 0%,#0D3324 36%,#175640 70%,#1F7351 100%);}
.hero-glow{position:absolute;inset:-25% -10% auto auto;width:70%;height:120%;z-index:0;pointer-events:none;background:radial-gradient(50% 50% at 70% 20%,rgba(183,214,43,.22),transparent 60%);animation:heroFloat 22s ease-in-out infinite alternate}
@keyframes heroFloat{0%{transform:translate3d(0,0,0)}100%{transform:translate3d(-4%,4%,0)}}
@media(prefers-reduced-motion:reduce){.hero-glow{animation:none}}
.hero-grain{position:absolute;inset:0;pointer-events:none;z-index:1;opacity:.5;mix-blend-mode:soft-light;background-image:radial-gradient(rgba(255,255,255,.6) .5px,transparent .6px);background-size:3px 3px}
.hero-content{position:relative;z-index:3;max-width:900px}
@media(max-width:820px){.hero{min-height:auto;padding-top:calc(68px + 44px)}}
.hero-kick{font-size:clamp(14px,1.6vw,16px);font-weight:500;color:rgba(245,240,232,.66);margin-bottom:22px}
.hero-h1{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(40px,7.5vw,84px);font-weight:800;letter-spacing:-0.045em;line-height:.95;color:var(--cream);margin:0;max-width:15ch;text-wrap:balance}
.hero-accent{color:var(--chartreuse)}
.hero-body{font-size:clamp(15px,1.8vw,19px);line-height:1.65;color:rgba(245,240,232,0.8);max-width:48ch;margin:28px 0 0}
.hero-ctas{display:flex;gap:22px;flex-wrap:wrap;align-items:center;margin-top:34px}
.hero-link{font-size:14px;font-weight:600;color:var(--cream);text-decoration:none;border-bottom:1.5px solid rgba(245,240,232,.5);padding-bottom:2px;transition:border-color .15s}
.hero-link:hover{border-color:var(--cream)}

/* ===== section scaffolding ===== */
.sec{background:var(--cream);padding:clamp(56px,8vw,104px) var(--pad)}
.sec-in{max-width:1160px;margin:0 auto}
.sec--line .sec-in{border-top:1px solid rgba(21,20,15,.12);padding-top:clamp(48px,7vw,84px)}
.u-ch{box-shadow:inset 0 -.30em 0 rgba(183,214,43,.5)}

/* ===== belief ===== */
.belief-h{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(30px,5.4vw,60px);line-height:1.0;letter-spacing:-.04em;font-weight:800;color:var(--ink);max-width:17ch;text-wrap:balance;margin:0}
.belief-p{margin:26px 0 0;color:var(--ink-2);max-width:54ch;font-size:clamp(16px,1.8vw,19px);line-height:1.6}

/* ===== the work ===== */
.work-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(21,20,15,.12);border:1px solid rgba(21,20,15,.12);border-radius:14px;overflow:hidden;margin-top:clamp(28px,4vw,44px)}
@media(max-width:800px){.work-grid{grid-template-columns:1fr}}
.work-card{background:var(--card);padding:clamp(26px,3vw,40px);display:flex;flex-direction:column;min-height:240px;text-decoration:none;transition:background .2s}
.work-card:hover{background:#fff}
.work-q{font-family:'DM Mono',ui-monospace,monospace;font-size:13px;color:var(--chartreuse-deep);font-weight:500}
.work-title{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(20px,2.6vw,27px);font-weight:800;letter-spacing:-.02em;color:var(--ink);margin:16px 0 12px}
.work-body{font-size:14.5px;line-height:1.65;color:var(--ink-2);flex:1}
.work-more{margin-top:20px;font-size:12px;font-weight:700;letter-spacing:.02em;color:var(--chartreuse-deep)}
.work-foot{margin-top:22px;font-size:13px;color:var(--gray)}
.work-foot a{color:var(--ink);font-weight:600;border-bottom:1.5px solid var(--chartreuse);text-decoration:none;padding-bottom:1px}

/* ===== proof / numbers ===== */
.proof-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(20px,3vw,44px);margin-top:clamp(24px,3vw,40px)}
@media(max-width:720px){.proof-grid{grid-template-columns:1fr;gap:0}}
.proof-item{padding:26px 0;border-top:2px solid var(--ink)}
@media(max-width:720px){.proof-item{border-top:1px solid rgba(21,20,15,.12)}.proof-item:first-child{border-top:2px solid var(--ink)}}
.proof-n{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:clamp(42px,6vw,68px);font-weight:800;letter-spacing:-.04em;line-height:1;color:var(--ink)}
.proof-n u{text-decoration:none;box-shadow:inset 0 -.16em 0 rgba(183,214,43,.65)}
.proof-t{margin:14px 0 0;font-size:14.5px;color:var(--ink-2);max-width:30ch;line-height:1.55}

/* ===== the way we work ===== */
.howwork-grid{display:grid;grid-template-columns:.9fr 1.1fr;gap:clamp(24px,5vw,64px);align-items:start}
@media(max-width:800px){.howwork-grid{grid-template-columns:1fr}}
.howwork-lead{margin-top:20px;color:var(--ink-2);max-width:34ch;font-size:16px;line-height:1.6}
.howwork-list{display:flex;flex-direction:column}
.howwork-item{display:grid;grid-template-columns:auto 1fr;gap:20px;padding:24px 0;border-top:1px solid rgba(21,20,15,.12)}
.howwork-item:first-child{border-top:none}
.hw-k{font-family:'DM Mono',ui-monospace,monospace;font-size:13px;color:var(--chartreuse-deep);font-weight:500;padding-top:3px}
.howwork-item h4{font-family:'Bricolage Grotesque Variable',sans-serif;margin:0 0 7px;font-size:18px;font-weight:700;letter-spacing:-.01em;color:var(--ink)}
.howwork-item p{margin:0;font-size:15px;color:var(--ink-2);line-height:1.55}

/* ===== insights ===== */
.ins-head{display:flex;align-items:flex-end;justify-content:space-between;gap:20px;flex-wrap:wrap;margin-bottom:clamp(24px,3vw,40px)}
.ins-all{font-size:12px;font-weight:700;color:var(--ink);border:1px solid rgba(21,20,15,.22);border-radius:8px;padding:10px 16px;text-decoration:none;transition:border-color .15s}
.ins-all:hover{border-color:var(--ink)}
.ins-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(14px,2vw,22px)}
@media(max-width:820px){.ins-grid{grid-template-columns:1fr 1fr}}
@media(max-width:560px){.ins-grid{grid-template-columns:1fr}}
.ins-card{background:var(--card);border:1px solid rgba(21,20,15,.12);border-radius:12px;padding:24px;display:flex;flex-direction:column;gap:15px;min-height:200px;text-decoration:none;transition:border-color .15s,transform .12s}
.ins-card:hover{border-color:rgba(21,20,15,.22);transform:translateY(-2px)}
.ins-tag{font-size:13px;font-weight:600;color:var(--chartreuse-deep)}
.ins-title{font-family:'Bricolage Grotesque Variable',sans-serif;font-size:18px;font-weight:700;letter-spacing:-.015em;line-height:1.22;color:var(--ink)}
.ins-meta{margin-top:auto;font-size:13px;color:var(--gray)}
.ins-empty{padding:48px;text-align:center;font-size:14px;color:var(--gray);background:var(--linen);border-radius:12px}
</style>
